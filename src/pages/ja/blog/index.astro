---
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/translations';

const t = useTranslations('ja');

// Sample blog posts - in production, these would come from content collections
const posts = [
  {
    slug: 'why-recipe-websites-are-so-annoying',
    title: 'レシピサイトが「あんなに」うっとうしい理由（と、私たちの対策）',
    excerpt: 'クッキーを作りたいだけなのに、誰かのおばあちゃんについて2,000文字読まされる。なぜ料理ブログはこうなのか、そしてKitchenoteがどう解決するのか。',
    date: '2024-01-15',
    readTime: '4分で読める',
    category: '考察'
  },
  {
    slug: 'scaling-recipes-the-right-way',
    title: 'レシピの分量調整：単純な掛け算じゃダメな理由',
    excerpt: '材料を2倍にすれば全部2倍？実はそうじゃない。レシピを増やす（または減らす）時に料理を台無しにしないコツをご紹介。',
    date: '2024-01-10',
    readTime: '5分で読める',
    category: 'コツ'
  },
  {
    slug: 'organize-your-recipe-collection',
    title: 'レシピ整理、実際に使える5つの方法',
    excerpt: 'フォルダ？タグ？コレクション？欲しい時に欲しいものが見つかる、実践的なレシピ整理ガイド。',
    date: '2024-01-05',
    readTime: '3分で読める',
    category: 'コツ'
  }
];

function formatDate(dateString: string): string {
  return new Date(dateString).toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<Layout title="ブログ" description="料理のコツ、レシピ、家庭料理についての考察。Kitchenoteブログ。">

  <!-- Hero -->
  <section class="py-16 md:py-24">
    <div class="container-narrow text-center">
      <h1 class="mb-4">{t('blog.title')}</h1>
      <p class="text-lg text-neutral-600">
        {t('blog.subtitle')}
      </p>
    </div>
  </section>

  <!-- Posts -->
  <section class="pb-20">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <article class="card group hover:border-primary-200 transition-all duration-300">
            <!-- Category badge -->
            <div class="mb-4">
              <span class="inline-block px-3 py-1 text-xs font-medium text-sage-700 bg-sage-50 rounded-full">
                {post.category}
              </span>
            </div>

            <!-- Title -->
            <h2 class="text-xl font-display font-bold mb-3 group-hover:text-primary-600 transition-colors">
              <a href={`/ja/blog/${post.slug}`} class="hover:text-primary-600">
                {post.title}
              </a>
            </h2>

            <!-- Excerpt -->
            <p class="text-neutral-600 text-sm leading-relaxed mb-4">
              {post.excerpt}
            </p>

            <!-- Meta -->
            <div class="flex items-center justify-between text-sm text-neutral-500">
              <time datetime={post.date}>{formatDate(post.date)}</time>
              <span>{post.readTime}</span>
            </div>

            <!-- Read more link -->
            <a
              href={`/ja/blog/${post.slug}`}
              class="inline-flex items-center gap-1 mt-4 text-primary-600 hover:text-primary-700 font-medium text-sm"
            >
              {t('blog.readMore')}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter signup -->
  <section class="py-16 bg-white">
    <div class="container-narrow text-center">
      <h2 class="text-2xl font-display font-bold mb-4">
        料理のコツをメールで受け取る
      </h2>
      <p class="text-neutral-600 mb-6">
        レシピ、料理のコツ、Kitchenoteのアップデートをお届けします。スパムなし、いつでも解除可能。
      </p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          placeholder="your@email.com"
          class="flex-1 px-4 py-3 rounded-full border border-cream-300 focus:outline-none focus:border-primary-400 focus:ring-2 focus:ring-primary-100"
          required
        />
        <button type="submit" class="btn-primary">
          登録する
        </button>
      </form>
      <p class="text-xs text-neutral-500 mt-4">
        プライバシーを尊重します。<a href="/ja/privacy" class="underline">プライバシーポリシー</a>をご覧ください。
      </p>
    </div>
  </section>

</Layout>
