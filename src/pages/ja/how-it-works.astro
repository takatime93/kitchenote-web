---
import Layout from '../../layouts/Layout.astro';
import PhoneMockup from '../../components/PhoneMockup.astro';
import WaitlistForm from '../../components/WaitlistForm.astro';
import { useTranslations } from '../../i18n/translations';
const t = useTranslations('ja');
---

<Layout title="使い方" description="Kitchenoteでのレシピ保存と整理がいかに簡単か、4つのステップでご紹介します。">

  <section class="py-16 md:py-24">
    <div class="container-narrow text-center">
      <h1 class="mb-6">Kitchenoteの使い方</h1>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">4ステップ。30秒で分かります。</p>
    </div>
  </section>

  <!-- Step 1 -->
  <section class="step-section py-12 md:py-20 bg-white">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div>
          <div class="step-number">1</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">好きなレシピを見つける</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">どこからでもOK。お気に入りの料理ブログ、友達がおすすめしてくれたレシピ、YouTubeの動画、おばあちゃんがLINEで送ってくれたレシピ。ウェブにあるものなら保存できます。</p>
          <div class="tip-box">コピー制限のあるサイトを含め、95%のレシピサイトに対応。</div>
        </div>
        <div class="animate-on-scroll">
          <PhoneMockup>
            <div class="demo-browse">
              <div class="demo-safari-bar">
                <div class="safari-dots"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>
                <div class="safari-url"><span class="safari-lock">🔒</span><span class="safari-domain">cookpad.com</span></div>
              </div>
              <div class="demo-webpage">
                <div class="webpage-hero"></div>
                <div class="webpage-title">チキンティッカマサラ</div>
                <div class="webpage-rating">★★★★★ 4.8（2,340件）</div>
                <div class="webpage-text line-1"></div>
                <div class="webpage-text line-2"></div>
                <div class="webpage-text line-3"></div>
                <div class="webpage-ad">広告</div>
                <div class="webpage-text line-4"></div>
                <div class="webpage-text line-5"></div>
                <div class="webpage-scroll-hint"><span>↓ レシピまでスクロール...</span></div>
              </div>
            </div>
          </PhoneMockup>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 2 -->
  <section class="step-section py-12 md:py-20">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div class="animate-on-scroll md:order-1">
          <PhoneMockup>
            <div class="demo-share">
              <div class="share-backdrop"></div>
              <div class="share-sheet">
                <div class="share-handle"></div>
                <div class="share-title">共有先...</div>
                <div class="share-apps">
                  <div class="share-app"><div class="share-icon">💬</div><span>メッセージ</span></div>
                  <div class="share-app"><div class="share-icon">✉️</div><span>メール</span></div>
                  <div class="share-app share-app-highlight">
                    <div class="share-icon icon-kn"><svg width="18" height="18" viewBox="0 0 32 32" fill="none"><rect width="32" height="32" rx="8" fill="#e86f4c"/><path d="M8 10h16M8 16h12M8 22h8" stroke="white" stroke-width="2.5" stroke-linecap="round"/></svg></div>
                    <span>Kitchenote</span>
                  </div>
                  <div class="share-app"><div class="share-icon">📝</div><span>メモ</span></div>
                </div>
                <div class="share-actions">
                  <div class="share-action">リンクをコピー</div>
                  <div class="share-action">ブックマークに追加</div>
                </div>
              </div>
            </div>
          </PhoneMockup>
        </div>
        <div class="md:order-2">
          <div class="step-number">2</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Kitchenoteにシェア</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">共有ボタンをタップして、Kitchenoteを選ぶだけ。URLをコピペしてもOK。2秒で完了。</p>
          <div class="tip-box">共有シートからの方が速いですが、コピペでも問題なし。</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 3 -->
  <section class="step-section py-12 md:py-20 bg-white">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div>
          <div class="step-number">3</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">魔法を見届ける</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">ページを読み込み、必要な情報だけを抽出。タイトル、材料、手順、調理時間、写真。余計なものは一切なし。</p>
          <div class="tip-box">保存後はいつでも編集やメモの追加ができます。</div>
        </div>
        <div class="animate-on-scroll">
          <PhoneMockup>
            <div class="demo-extract">
              <div class="demo-kn-header"><span class="demo-kn-title">取り込み中...</span></div>
              <div class="extract-content">
                <div class="extract-progress"><div class="extract-progress-fill"></div></div>
                <div class="extract-status">ページを読み込み中...</div>
                <div class="extract-items">
                  <div class="extract-item ei-1"><span class="extract-check">✓</span> タイトルを検出</div>
                  <div class="extract-item ei-2"><span class="extract-check">✓</span> 材料12点</div>
                  <div class="extract-item ei-3"><span class="extract-check">✓</span> 手順6ステップ</div>
                  <div class="extract-item ei-4"><span class="extract-check">✓</span> 調理時間: 45分</div>
                  <div class="extract-item ei-5"><span class="extract-check">✓</span> 写真を保存</div>
                </div>
                <div class="extract-done">
                  <div class="extract-done-icon">✨</div>
                  <div class="extract-done-text">レシピを保存しました！</div>
                </div>
              </div>
            </div>
          </PhoneMockup>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="step-section py-12 md:py-20">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">違いを見てください</h2>
        <p class="text-neutral-600 max-w-2xl mx-auto">同じレシピ。まったく違う体験。</p>
      </div>
      <div class="comparison animate-on-scroll">
        <div class="comparison-grid">
          <div class="compare-side compare-website">
            <div class="compare-label compare-label-bad">レシピサイト</div>
            <PhoneMockup>
              <div class="web-mess">
                <div class="web-mess-bar">
                  <div class="web-mess-dots"><span></span><span></span><span></span></div>
                  <div class="web-mess-url">cookpad.com/recipe/7654321</div>
                </div>
                <div class="web-mess-content">
                  <div class="web-mess-popup">
                    <div class="popup-x">✕</div>
                    <div class="popup-text">無料レシピを受け取る！</div>
                    <div class="popup-input"></div>
                  </div>
                  <div class="web-mess-hero-img"></div>
                  <div class="web-mess-title">人生で最高のチキンティッカマサラ！</div>
                  <div class="web-mess-meta">ジェシカ · 2025年3月12日 · コメント847件</div>
                  <div class="web-mess-story"><div class="wm-line" style="width:100%"></div><div class="wm-line" style="width:92%"></div><div class="wm-line" style="width:88%"></div></div>
                  <div class="web-mess-ad">広告</div>
                  <div class="web-mess-story"><div class="wm-line" style="width:95%"></div><div class="wm-line" style="width:85%"></div><div class="wm-line" style="width:90%"></div></div>
                  <div class="web-mess-inline-img"></div>
                  <div class="web-mess-story"><div class="wm-line" style="width:100%"></div><div class="wm-line" style="width:88%"></div></div>
                  <div class="web-mess-ad">スポンサー</div>
                  <div class="web-mess-story"><div class="wm-line" style="width:92%"></div><div class="wm-line" style="width:80%"></div></div>
                  <div class="web-mess-story"><div class="wm-line" style="width:94%"></div><div class="wm-line" style="width:82%"></div></div>
                </div>
              </div>
            </PhoneMockup>
            <div class="compare-issues">
              <div class="issue">❌ 長い前置き</div>
              <div class="issue">❌ ポップアップと広告</div>
              <div class="issue">❌ ネット接続が必要</div>
              <div class="issue">❌ 人数変更できない</div>
            </div>
          </div>
          <div class="compare-side compare-app">
            <div class="compare-label compare-label-good">Kitchenoteなら</div>
            <PhoneMockup>
              <div class="app-clean">
                <div class="app-clean-header">
                  <span class="app-clean-back">‹</span>
                  <span class="app-clean-title">チキンティッカマサラ</span>
                  <span class="app-clean-edit">✎</span>
                </div>
                <div class="app-clean-img"></div>
                <div class="app-clean-body">
                  <div class="app-clean-name">チキンティッカマサラ</div>
                  <div class="app-clean-meta-row">
                    <span class="app-meta-pill">🕐 45分</span>
                    <span class="app-meta-pill">👤 4人分</span>
                    <span class="app-meta-pill">⭐ 保存済み</span>
                  </div>
                  <div class="app-clean-section-title">材料</div>
                  <div class="app-clean-ing"><span class="ing-qty">500g</span> 鶏もも肉</div>
                  <div class="app-clean-ing"><span class="ing-qty">1カップ</span> ヨーグルト</div>
                  <div class="app-clean-ing"><span class="ing-qty">大さじ2</span> ガラムマサラ</div>
                  <div class="app-clean-ing"><span class="ing-qty">400g</span> トマト缶</div>
                  <div class="app-clean-ing"><span class="ing-qty">大さじ1</span> オリーブオイル</div>
                  <div class="app-clean-section-title">手順</div>
                  <div class="app-clean-step"><span class="step-num">1</span> 鶏肉をヨーグルトとスパイスで30分漬ける</div>
                  <div class="app-clean-step"><span class="step-num">2</span> 油を熱し、鶏肉をきつね色になるまで焼く</div>
                </div>
                <div class="app-clean-cook-btn">🍳 クックモード開始</div>
              </div>
            </PhoneMockup>
            <div class="compare-wins">
              <div class="win">✅ レシピだけ</div>
              <div class="win">✅ 広告なし</div>
              <div class="win">✅ オフライン対応</div>
              <div class="win">✅ 人数分の自動計算</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 4 -->
  <section class="step-section py-12 md:py-20">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div class="animate-on-scroll md:order-1">
          <PhoneMockup>
            <div class="demo-final">
              <div class="demo-kn-header"><span class="demo-kn-title">マイレシピ</span></div>
              <div class="final-grid">
                <div class="final-card fc-1"><div class="final-thumb" style="background:url("/images/recipes/tikka-masala.jpg") center/cover;"></div><div class="final-info"><div class="final-name">ティッカマサラ</div><div class="final-time">45分</div></div></div>
                <div class="final-card fc-2"><div class="final-thumb" style="background:url("/images/recipes/caesar-salad.jpg") center/cover;"></div><div class="final-info"><div class="final-name">シーザーサラダ</div><div class="final-time">15分</div></div></div>
                <div class="final-card fc-3"><div class="final-thumb" style="background:url("/images/recipes/banana-bread.jpg") center/cover;"></div><div class="final-info"><div class="final-name">バナナブレッド</div><div class="final-time">60分</div></div></div>
                <div class="final-card fc-4"><div class="final-thumb" style="background:url("/images/recipes/pad-thai.jpg") center/cover;"></div><div class="final-info"><div class="final-name">パッタイ</div><div class="final-time">30分</div></div></div>
                <div class="final-card fc-5"><div class="final-thumb" style="background:url("/images/recipes/berry-smoothie.jpg") center/cover;"></div><div class="final-info"><div class="final-name">ベリースムージー</div><div class="final-time">5分</div></div></div>
                <div class="final-card fc-6"><div class="final-thumb" style="background:url("/images/recipes/miso-soup.jpg") center/cover;"></div><div class="final-info"><div class="final-name">味噌汁</div><div class="final-time">20分</div></div></div>
              </div>
              <div class="final-cook-btn"><span>🍳</span> 料理を始める</div>
            </div>
          </PhoneMockup>
        </div>
        <div class="md:order-2">
          <div class="step-number">4</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">好きな時に料理する</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">レシピは保存・整理され、いつでも待機状態。クックモードを開けば大きな文字でステップ表示。邪魔なものは何もなし。</p>
          <div class="tip-box">すべてのレシピはオフラインで使えます。</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Beyond the basics -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container-narrow text-center">
      <div class="beyond-divider"><span class="beyond-line"></span><span class="beyond-text">さらに便利に</span><span class="beyond-line"></span></div>
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4 mt-8">料理はみんなでもっと楽しく</h2>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">Kitchenoteはレシピを保存するだけじゃない。家族の食の文化が生きる場所です。</p>
    </div>
  </section>

  <section class="py-12 md:py-20">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div>
          <div class="step-number step-collab">📖</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">レシピブックをみんなで共有</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">パートナー、家族、友達と共有レシピブックを作成。みんながレシピを追加し、メモを残し、リアルタイムで更新を確認できます。</p>
          <div class="tip-box">フリーユーザーは2冊まで。プレミアムは無制限。</div>
        </div>
        <div class="animate-on-scroll">
          <div class="collab-visual">
            <div class="collab-cookbook animate-on-scroll">
              <div class="collab-book-icon">📖</div>
              <div class="collab-book-info"><div class="collab-book-name">家族のお気に入り</div><div class="collab-book-count">23レシピ</div></div>
              <div class="collab-avatars"><div class="c-avatar ca-1">Y</div><div class="c-avatar ca-2">T</div><div class="c-avatar ca-3">M</div><div class="c-avatar ca-4">+2</div></div>
            </div>
            <div class="collab-feed">
              <div class="collab-notif cn-1 animate-on-scroll"><div class="c-avatar ca-small ca-mom">M</div><div class="cn-content"><div class="cn-text"><strong>ママ</strong>が<em>おばあちゃんのアップルパイ</em>を追加</div><div class="cn-time">2分前</div></div></div>
              <div class="collab-notif cn-2 animate-on-scroll"><div class="c-avatar ca-small ca-dad">D</div><div class="cn-content"><div class="cn-text"><strong>パパ</strong>がコメント「シナモンを足してみて！」</div><div class="cn-time">15分前</div></div></div>
              <div class="collab-notif cn-3 animate-on-scroll"><div class="c-avatar ca-small ca-sis">S</div><div class="cn-content"><div class="cn-text"><strong>さくら</strong>があなたのパッタイを保存</div><div class="cn-time">1時間前</div></div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div class="animate-on-scroll md:order-1">
          <div class="version-visual">
            <div class="ver-card ver-original">
              <div class="ver-badge ver-badge-original">オリジナル</div>
              <div class="ver-img" style="background:url('/images/recipes/tikka-masala.jpg') center/cover;"></div>
              <div class="ver-body"><div class="ver-name">ママのカレー</div><div class="ver-detail"><div class="ver-ing">マイルドカレー粉 大さじ2</div><div class="ver-ing">ココナッツミルク 1カップ</div><div class="ver-ing">鶏むね肉 400g</div></div></div>
            </div>
            <div class="ver-fork-arrow"><svg width="40" height="40" viewBox="0 0 40 40" fill="none"><path d="M12 20h16M22 14l6 6-6 6" stroke="#e86f4c" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
            <div class="ver-card ver-yours">
              <div class="ver-badge ver-badge-yours">あなたのバージョン</div>
              <div class="ver-img" style="background:url('/images/recipes/tikka-masala.jpg') center/cover;filter:hue-rotate(15deg) saturate(1.2);"></div>
              <div class="ver-body"><div class="ver-name">激辛カレー 🔥</div><div class="ver-detail"><div class="ver-ing ver-changed"><span class="ver-strike">マイルド大さじ2</span> → ホット大さじ3</div><div class="ver-ing">ココナッツミルク 1カップ</div><div class="ver-ing ver-changed"><span class="ver-strike">むね肉</span> → もも肉</div><div class="ver-ing ver-added">+ タイ唐辛子 2本</div></div></div>
            </div>
          </div>
        </div>
        <div class="md:order-2">
          <div class="step-number step-collab">✏️</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">フォークして自分流に</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">もっと辛くしたい？フォークして、材料を入れ替え、分量を調整、自分のメモを追加。すべてオリジナルに影響なし。</p>
          <div class="tip-box">コメントで工夫をシェア：「にんにく多めで作ったら最高だった」</div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div>
          <div class="step-number step-collab">🤖</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">AIキッチンアシスタント</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">乳製品フリーにしたい？冷蔵庫の残り物で何が作れる？AIアシスタントがスマートな代替提案、レシピの精度チェック、食事制限に合わせたアレンジをお手伝い。</p>
          <div class="tip-box">プレミアム限定機能。料理をなんでも知っている頼れる友達。</div>
        </div>
        <div class="animate-on-scroll">
          <div class="ai-visual">
            <div class="ai-chat">
              <div class="ai-msg ai-user"><div class="ai-bubble ai-bubble-user">このレシピを乳製品フリーにして</div></div>
              <div class="ai-msg ai-assistant">
                <div class="ai-avatar">✨</div>
                <div class="ai-bubble ai-bubble-assistant">
                  <div class="ai-typing">提案があります：</div>
                  <div class="ai-suggestion as-1"><span class="ai-swap-old">バター（½カップ）</span><span class="ai-swap-arrow">→</span><span class="ai-swap-new">ココナッツオイル（½カップ）</span></div>
                  <div class="ai-suggestion as-2"><span class="ai-swap-old">牛乳（1カップ）</span><span class="ai-swap-arrow">→</span><span class="ai-swap-new">オーツミルク（1カップ）</span></div>
                  <div class="ai-suggestion as-3"><span class="ai-swap-old">生クリーム（½カップ）</span><span class="ai-swap-arrow">→</span><span class="ai-swap-new">ココナッツクリーム（½カップ）</span></div>
                </div>
              </div>
              <div class="ai-msg ai-assistant ai-audit">
                <div class="ai-avatar">🔍</div>
                <div class="ai-bubble ai-bubble-assistant">
                  <div class="ai-typing">レシピ監査：</div>
                  <div class="ai-audit-item aa-1">✅ 温度設定は正確です</div>
                  <div class="ai-audit-item aa-2">✅ 調理時間を確認済み</div>
                  <div class="ai-audit-item aa-3">⚠️ 塩を¾小さじに減らすことをおすすめ</div>
                </div>
              </div>
            </div>
            <div class="ai-apply-btn">すべての提案を適用</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16">
    <div class="container-narrow">
      <h2 class="text-2xl font-display font-bold text-center mb-8">よくある質問</h2>
      <div class="space-y-4">
        <details class="group card">
          <summary class="flex items-center justify-between cursor-pointer list-none font-medium">レシピが正しくインポートできない場合は？<svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></summary>
          <p class="mt-3 text-neutral-600">まれに正しく読み込めない場合があります。手動で編集可能です。パーサーは常に改良中です。</p>
        </details>
        <details class="group card">
