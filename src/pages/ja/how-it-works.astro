---
import Layout from '../../layouts/Layout.astro';
import PhoneMockup from '../../components/PhoneMockup.astro';
import WaitlistForm from '../../components/WaitlistForm.astro';
---

<Layout title="使い方" description="Kitchenoteでのレシピ保存、共有、調理がいかに簡単か。あらゆるサイトからインポート、家族とコラボ、静かに賢いインテリジェンス。">

  <!-- Hero -->
  <section class="py-8 md:py-12 lg:py-20">
    <div class="container-narrow text-center">
      <h1 class="mb-4">Kitchenoteの使い方</h1>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
        レシピの保存、共有、調理に必要なすべてが一つのアプリに。
      </p>
    </div>
  </section>

  <!-- Tab Bar -->
  <div class="tab-bar-wrapper">
    <div class="container-wide">
      <div class="tab-bar">
        <button class="tab-btn tab-active" data-tab="import">
          <span class="tab-icon">📥</span>
          <span class="tab-label-short">保存</span>
          <span class="tab-label">保存＆調理</span>
        </button>
        <button class="tab-btn" data-tab="sharing">
          <span class="tab-icon">👨‍👩‍👧‍👦</span>
          <span class="tab-label-short">共有</span>
          <span class="tab-label">共有＆コラボ</span>
        </button>
        <button class="tab-btn" data-tab="ai">
          <span class="tab-icon">🧠</span>
          <span class="tab-label-short">AI</span>
          <span class="tab-label">組み込みAI</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ============================================ -->
  <!--  TAB 1: SAVE & COOK                         -->
  <!-- ============================================ -->
  <div class="tab-panel tab-panel-active" id="panel-import">

    <!-- Step 1: Find -->
    <section class="py-8 md:py-12 lg:py-20 bg-white">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div>
            <div class="step-number">1</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">好きなレシピを見つける</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              どこからでもOK。お気に入りの料理ブログ、YouTube動画、おばあちゃんがLINEで送ってくれたレシピ。ウェブにあるものなら保存できます。
            </p>
            <div class="tip-box">コピー制限のあるサイトを含め、95%のレシピサイトに対応。</div>
          </div>
          <div class="animate-on-scroll hidden md:block">
            <PhoneMockup>
              <div class="demo-browse">
                <div class="demo-safari-bar">
                  <div class="safari-dots"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>
                  <div class="safari-url"><span class="safari-lock">🔒</span><span class="safari-domain">allrecipes.com</span></div>
                </div>
                <div class="demo-webpage">
                  <div class="webpage-hero"></div>
                  <div class="webpage-title">Chicken ティッカマサラ</div>
                  <div class="webpage-rating">★★★★★ 4.8 (2,340 reviews)</div>
                  <div class="webpage-text line-1"></div><div class="webpage-text line-2"></div><div class="webpage-text line-3"></div>
                  <div class="webpage-ad">ADVERTISEMENT</div>
                  <div class="webpage-text line-4"></div><div class="webpage-text line-5"></div>
                  <div class="webpage-inline-img"></div>
                  <div class="webpage-text line-1"></div><div class="webpage-text line-2"></div>
                  <div class="webpage-ad">SPONSORED</div>
                  <div class="webpage-text line-3"></div><div class="webpage-text line-4"></div>
                </div>
              </div>
            </PhoneMockup>
          </div>
        </div>
      </div>
    </section>

    <!-- Step 2: Share -->
    <section class="py-8 md:py-12 lg:py-20">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div class="animate-on-scroll hidden md:block md:order-1">
            <PhoneMockup>
              <div class="demo-share">
                <div class="share-backdrop"></div>
                <div class="share-sheet">
                  <div class="share-handle"></div>
                  <div class="share-title">共有先...</div>
                  <div class="share-apps">
                    <div class="share-app"><div class="share-icon">💬</div><span>メッセージ</span></div>
                    <div class="share-app"><div class="share-icon">✉️</div><span>メール</span></div>
                    <div class="share-app share-app-highlight">
                      <div class="share-icon icon-kn"><svg width="18" height="18" viewBox="0 0 32 32" fill="none"><rect width="32" height="32" rx="8" fill="#e86f4c"/><path d="M8 10h16M8 16h12M8 22h8" stroke="white" stroke-width="2.5" stroke-linecap="round"/></svg></div>
                      <span>Kitchenote</span>
                    </div>
                    <div class="share-app"><div class="share-icon">📝</div><span>メモ</span></div>
                  </div>
                  <div class="share-actions"><div class="share-action">リンクをコピー</div><div class="share-action">ブックマークに追加</div></div>
                </div>
              </div>
            </PhoneMockup>
          </div>
          <div class="md:order-2">
            <div class="step-number">2</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Kitchenoteにシェア</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              共有ボタンをタップしてKitchenoteを選ぶだけ。URLをコピペしてもOK。2秒で完了。
            </p>
            <div class="tip-box">共有シートからの方が速いですが、コピペでも問題なし。</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Step 3: Extract -->
    <section class="py-8 md:py-12 lg:py-20 bg-white">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div>
            <div class="step-number">3</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">魔法を見届ける</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              ページを読み込み、必要な情報だけを抽出。タイトル、材料、手順、調理時間、写真。
            </p>
            <div class="tip-box">保存後はいつでも編集やメモの追加ができます。</div>
          </div>
          <div class="animate-on-scroll hidden md:block">
            <PhoneMockup>
              <div class="demo-extract">
                <div class="demo-kn-header"><span class="demo-kn-title">取り込み中...</span></div>
                <div class="extract-content">
                  <div class="extract-progress"><div class="extract-progress-fill"></div></div>
                  <div class="extract-status">ページを読み込み中...</div>
                  <div class="extract-items">
                    <div class="extract-item ei-1"><span class="extract-check">✓</span> タイトルを検出</div>
                    <div class="extract-item ei-2"><span class="extract-check">✓</span> 材料12点</div>
                    <div class="extract-item ei-3"><span class="extract-check">✓</span> 手順6ステップ</div>
                    <div class="extract-item ei-4"><span class="extract-check">✓</span> 調理時間: 45分</div>
                    <div class="extract-item ei-5"><span class="extract-check">✓</span> 写真を保存</div>
                  </div>
                  <div class="extract-done"><div class="extract-done-icon">✨</div><div class="extract-done-text">レシピを保存しました！</div></div>
                </div>
              </div>
            </PhoneMockup>
          </div>
        </div>
      </div>
    </section>

    <!-- Comparison: Website vs App -->
    <section class="py-8 md:py-12 lg:py-20">
      <div class="container-wide">
        <div class="text-center mb-12">
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">違いを見てください</h2>
          <p class="text-neutral-600">同じレシピ。まったく違う体験。</p>
        </div>
        <div class="comparison animate-on-scroll">
          <div class="comparison-grid">
            <div class="compare-side">
              <div class="compare-label compare-label-bad">レシピサイト</div>
              <div class="hidden md:block">
              <PhoneMockup>
                <div class="web-mess">
                  <div class="web-mess-bar"><div class="web-mess-dots"><span></span><span></span><span></span></div><div class="web-mess-url">foodblog.com/best-ever-tikka</div></div>
                  <div class="web-mess-content">
                    <div class="web-mess-popup"><div class="popup-x">✕</div><div class="popup-text">無料レシピを受け取る！</div><div class="popup-input"></div></div>
                    <div class="web-mess-hero-img"></div>
                    <div class="web-mess-title">人生最高のチキンティッカマサラ！</div>
                    <div class="web-mess-meta">ジェシカ · 2025年3月 · コメント847件</div>
                    <div class="web-mess-story"><div class="wm-line" style="width:100%"></div><div class="wm-line" style="width:92%"></div><div class="wm-line" style="width:88%"></div></div>
                    <div class="web-mess-ad">ADVERTISEMENT</div>
                    <div class="web-mess-story"><div class="wm-line" style="width:95%"></div><div class="wm-line" style="width:85%"></div><div class="wm-line" style="width:90%"></div></div>
                    <div class="web-mess-inline-img"></div>
                    <div class="web-mess-ad">SPONSORED</div>
                    <div class="web-mess-story"><div class="wm-line" style="width:92%"></div><div class="wm-line" style="width:80%"></div></div>
                  </div>
                </div>
              </PhoneMockup>
              </div>
              <div class="compare-list"><div class="issue">❌ 長い前置き</div><div class="issue">❌ ポップアップと広告</div><div class="issue">❌ ネット接続が必要</div><div class="issue">❌ 人数変更できない</div></div>
            </div>
            <div class="compare-side">
              <div class="compare-label compare-label-good">Kitchenoteなら</div>
              <div class="hidden md:block">
              <PhoneMockup>
                <div class="app-clean">
                  <div class="app-clean-header"><span class="app-clean-back">‹</span><span class="app-clean-title">Chicken ティッカマサラ</span><span class="app-clean-edit">✎</span></div>
                  <div class="app-clean-img"></div>
                  <div class="app-clean-body">
                    <div class="app-clean-name">Chicken ティッカマサラ</div>
                    <div class="app-clean-meta-row"><span class="app-meta-pill">🕐 45 min</span><span class="app-meta-pill">👤 4 servings</span><span class="app-meta-pill">⭐ Saved</span></div>
                    <div class="app-clean-section-title">Ingredients</div>
                    <div class="app-clean-ing"><span class="ing-qty">500g</span> chicken thigh</div>
                    <div class="app-clean-ing"><span class="ing-qty">1 cup</span> yogurt</div>
                    <div class="app-clean-ing"><span class="ing-qty">2 tbsp</span> garam masala</div>
                    <div class="app-clean-ing"><span class="ing-qty">400g</span> crushed tomatoes</div>
                    <div class="app-clean-ing"><span class="ing-qty">1 tbsp</span> オリーブオイル</div>
                    <div class="app-clean-section-title">Steps</div>
                    <div class="app-clean-step"><span class="step-num-sm">1</span> Marinate chicken in yogurt and spices for 30 min</div>
                    <div class="app-clean-step"><span class="step-num-sm">2</span> Heat oil, cook chicken until golden</div>
                  </div>
                  <div class="app-clean-cook-btn">🍳 Start Cook Mode</div>
                </div>
              </PhoneMockup>
              </div>
              <div class="compare-list"><div class="win">✅ レシピだけ</div><div class="win">✅ 広告なし</div><div class="win">✅ オフライン対応</div><div class="win">✅ 人数分の自動計算</div></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Step 4: Cook -->
    <section class="py-8 md:py-12 lg:py-20 bg-white">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div class="animate-on-scroll hidden md:block md:order-1">
            <PhoneMockup>
              <div class="demo-final">
                <div class="demo-kn-header"><span class="demo-kn-title">マイレシピ</span></div>
                <div class="final-grid">
                  <div class="final-card fc-1"><div class="final-thumb" style="background:url('/images/recipes/tikka-masala.jpg') center/cover;"></div><div class="final-info"><div class="final-name">ティッカマサラ</div><div class="final-time">45 min</div></div></div>
                  <div class="final-card fc-2"><div class="final-thumb" style="background:url('/images/recipes/caesar-salad.jpg') center/cover;"></div><div class="final-info"><div class="final-name">シーザーサラダ</div><div class="final-time">15 min</div></div></div>
                  <div class="final-card fc-3"><div class="final-thumb" style="background:url('/images/recipes/banana-bread.jpg') center/cover;"></div><div class="final-info"><div class="final-name">バナナブレッド</div><div class="final-time">60 min</div></div></div>
                  <div class="final-card fc-4"><div class="final-thumb" style="background:url('/images/recipes/pad-thai.jpg') center/cover;"></div><div class="final-info"><div class="final-name">パッタイ</div><div class="final-time">30 min</div></div></div>
                  <div class="final-card fc-5"><div class="final-thumb" style="background:url('/images/recipes/berry-smoothie.jpg') center/cover;"></div><div class="final-info"><div class="final-name">ベリースムージー</div><div class="final-time">5 min</div></div></div>
                  <div class="final-card fc-6"><div class="final-thumb" style="background:url('/images/recipes/miso-soup.jpg') center/cover;"></div><div class="final-info"><div class="final-name">味噌汁</div><div class="final-time">20 min</div></div></div>
                </div>
                <div class="final-cook-btn"><span>🍳</span> 料理を始める</div>
              </div>
            </PhoneMockup>
          </div>
          <div class="md:order-2">
            <div class="step-number">4</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">好きな時に料理する</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              レシピは保存・整理され、いつでも待機状態。クックモードで大きな文字、ステップ表示、邪魔なものゼロ。
            </p>
            <div class="tip-box">すべてのレシピはオフラインで使えます。</div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- ============================================ -->
  <!--  TAB 2: SHARE & COLLABORATE                  -->
  <!-- ============================================ -->
  <div class="tab-panel" id="panel-sharing">

    <!-- Shared Cookbooks -->
    <section class="py-8 md:py-12 lg:py-20 bg-white">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div>
            <div class="feature-emoji">📖</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">共有レシピブック</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              パートナー、家族、友達と共有レシピブックを作成。みんながレシピを追加し、メモを残し、リアルタイムで更新を確認できます。
            </p>
            <div class="tip-box">フリーユーザーは2冊まで。プレミアムは無制限。</div>
          </div>
          <div class="animate-on-scroll">
            <div class="collab-visual">
              <div class="collab-cookbook">
                <div class="collab-book-icon">📖</div>
                <div class="collab-book-info"><div class="collab-book-name">家族のお気に入り</div><div class="collab-book-count">23レシピ</div></div>
                <div class="collab-avatars"><div class="c-avatar ca-1">Y</div><div class="c-avatar ca-2">T</div><div class="c-avatar ca-3">M</div><div class="c-avatar ca-4">+2</div></div>
              </div>
              <div class="collab-feed">
                <div class="collab-notif cn-1 animate-on-scroll"><div class="c-avatar ca-small ca-mom">M</div><div class="cn-content"><div class="cn-text"><strong>ママ</strong>が<em>おばあちゃんのアップルパイ</em>を追加</div><div class="cn-time">2分前</div></div></div>
                <div class="collab-notif cn-2 animate-on-scroll"><div class="c-avatar ca-small ca-dad">D</div><div class="cn-content"><div class="cn-text"><strong>パパ</strong>がコメント「シナモンを足してみて！」</div><div class="cn-time">15分前</div></div></div>
                <div class="collab-notif cn-3 animate-on-scroll"><div class="c-avatar ca-small ca-sis">S</div><div class="cn-content"><div class="cn-text"><strong>さくら</strong> saved your パッタイ recipe</div><div class="cn-time">1時間前</div></div></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Versioning -->
    <section class="py-8 md:py-12 lg:py-20">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div class="animate-on-scroll md:order-1">
            <div class="version-visual">
              <div class="ver-card ver-original">
                <div class="ver-badge ver-badge-original">オリジナル</div>
                <div class="ver-img" style="background:url('/images/recipes/tikka-masala.jpg') center/cover;"></div>
                <div class="ver-body"><div class="ver-name">ママのカレー</div><div class="ver-detail"><div class="ver-ing">マイルドカレー粉 大さじ2</div><div class="ver-ing">ココナッツミルク 1カップ</div><div class="ver-ing">鶏むね肉 400g</div></div></div>
              </div>
              <div class="ver-fork-arrow"><svg width="40" height="40" viewBox="0 0 40 40" fill="none"><path d="M12 20h16M22 14l6 6-6 6" stroke="#e86f4c" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
              <div class="ver-card ver-yours">
                <div class="ver-badge ver-badge-yours">あなたのバージョン</div>
                <div class="ver-img" style="background:url('/images/recipes/tikka-masala.jpg') center/cover;filter:hue-rotate(15deg) saturate(1.2);"></div>
                <div class="ver-body"><div class="ver-name">激辛カレー 🔥</div><div class="ver-detail"><div class="ver-ing ver-changed"><span class="ver-strike">マイルド大さじ2</span> → ホット大さじ3</div><div class="ver-ing">ココナッツミルク 1カップ</div><div class="ver-ing ver-changed"><span class="ver-strike">むね肉</span> → thigh</div><div class="ver-ing ver-added">+ タイ唐辛子 2本</div></div></div>
              </div>
            </div>
          </div>
          <div class="md:order-2">
            <div class="feature-emoji">✏️</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">フォークして自分流に</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              もっと辛くしたい？フォークして、材料を入れ替え、分量を調整、メモを追加。すべてオリジナルに影響なし。
            </p>
            <div class="tip-box">コメントで工夫をシェア：「にんにく多めで作ったら最高だった」</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Friends & アクティビティ -->
    <section class="py-8 md:py-12 lg:py-20 bg-white">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div>
            <div class="feature-emoji">👥</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">好きな料理人をフォロー</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              友達や家族を追加。みんなが何を保存しているか見て、インスピレーションを得て、共有の食文化を作りましょう。
            </p>
            <div class="tip-box">フレンド＆ソーシャル機能はすべて無料。</div>
          </div>
          <div class="animate-on-scroll">
            <div class="friends-visual">
              <div class="friend-profile fp-1 animate-on-scroll">
                <div class="c-avatar ca-small ca-mom">M</div>
                <div class="fp-info"><div class="fp-name">ママ</div><div class="fp-stat">47レシピ · 3冊</div></div>
                <div class="fp-follow fp-following">フォロー中</div>
              </div>
              <div class="friend-profile fp-2 animate-on-scroll">
                <div class="c-avatar ca-small ca-dad">D</div>
                <div class="fp-info"><div class="fp-name">パパ</div><div class="fp-stat">12レシピ · BBQの達人</div></div>
                <div class="fp-follow fp-following">フォロー中</div>
              </div>
              <div class="friend-profile fp-3 animate-on-scroll">
                <div class="c-avatar ca-small ca-sis">S</div>
                <div class="fp-info"><div class="fp-name">さくら</div><div class="fp-stat">31レシピ · お菓子の女王</div></div>
                <div class="fp-follow fp-following">フォロー中</div>
              </div>
              <div class="friend-profile fp-4 animate-on-scroll">
                <div class="c-avatar ca-small" style="background:#8ecae6;">K</div>
                <div class="fp-info"><div class="fp-name">ケンジ</div><div class="fp-stat">89レシピ · 和食</div></div>
                <div class="fp-follow fp-add">+ フォロー</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Notifications -->
    <section class="py-8 md:py-12 lg:py-20">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div class="animate-on-scroll md:order-1">
            <div class="notif-visual">
              <div class="notif-header">アクティビティ</div>
              <div class="notif-item ni-1 animate-on-scroll">
                <div class="notif-dot notif-dot-new"></div>
                <div class="c-avatar ca-small ca-mom">M</div>
                <div class="notif-body"><strong>ママ</strong>が<em>おばあちゃんのアップルパイ</em>を追加 to 家族のお気に入り</div>
                <div class="notif-time">2分</div>
              </div>
              <div class="notif-item ni-2 animate-on-scroll">
                <div class="notif-dot notif-dot-new"></div>
                <div class="c-avatar ca-small ca-sis">S</div>
                <div class="notif-body"><strong>さくら</strong>があなたの<em>バナナブレッド</em>にコメント</div>
                <div class="notif-time">1時間</div>
              </div>
              <div class="notif-item ni-3 animate-on-scroll">
                <div class="notif-dot"></div>
                <div class="c-avatar ca-small ca-dad">D</div>
