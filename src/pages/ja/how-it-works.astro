---
import Layout from '../../layouts/Layout.astro';
import PhoneMockup from '../../components/PhoneMockup.astro';
import WaitlistForm from '../../components/WaitlistForm.astro';
import { useTranslations } from '../../i18n/translations';
const t = useTranslations('ja');
---

<Layout title="使い方" description="Kitchenoteでのレシピ保存と整理がいかに簡単か、4つのステップでご紹介します。">

  <section class="py-16 md:py-24">
    <div class="container-narrow text-center">
      <h1 class="mb-6">Kitchenoteの使い方</h1>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">4ステップ。30秒で分かります。</p>
    </div>
  </section>

  <!-- Step 1 -->
  <section class="step-section py-12 md:py-20 bg-white">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div>
          <div class="step-number">1</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">好きなレシピを見つける</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">どこからでもOK。お気に入りの料理ブログ、友達がおすすめしてくれたレシピ、YouTubeの動画、おばあちゃんがLINEで送ってくれたレシピ。ウェブにあるものなら保存できます。</p>
          <div class="tip-box">コピー制限のあるサイトを含め、95%のレシピサイトに対応。</div>
        </div>
        <div class="animate-on-scroll">
          <PhoneMockup>
            <div class="demo-browse">
              <div class="demo-safari-bar">
                <div class="safari-dots"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>
                <div class="safari-url"><span class="safari-lock">🔒</span><span class="safari-domain">cookpad.com</span></div>
              </div>
              <div class="demo-webpage">
                <div class="webpage-hero"></div>
                <div class="webpage-title">チキンティッカマサラ</div>
                <div class="webpage-rating">★★★★★ 4.8（2,340件）</div>
                <div class="webpage-text line-1"></div>
                <div class="webpage-text line-2"></div>
                <div class="webpage-text line-3"></div>
                <div class="webpage-ad">広告</div>
                <div class="webpage-text line-4"></div>
                <div class="webpage-text line-5"></div>
                <div class="webpage-scroll-hint"><span>↓ レシピまでスクロール...</span></div>
              </div>
            </div>
          </PhoneMockup>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 2 -->
  <section class="step-section py-12 md:py-20">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div class="animate-on-scroll md:order-1">
          <PhoneMockup>
            <div class="demo-share">
              <div class="share-backdrop"></div>
              <div class="share-sheet">
                <div class="share-handle"></div>
                <div class="share-title">共有先...</div>
                <div class="share-apps">
                  <div class="share-app"><div class="share-icon">💬</div><span>メッセージ</span></div>
                  <div class="share-app"><div class="share-icon">✉️</div><span>メール</span></div>
                  <div class="share-app share-app-highlight">
                    <div class="share-icon icon-kn"><svg width="18" height="18" viewBox="0 0 32 32" fill="none"><rect width="32" height="32" rx="8" fill="#e86f4c"/><path d="M8 10h16M8 16h12M8 22h8" stroke="white" stroke-width="2.5" stroke-linecap="round"/></svg></div>
                    <span>Kitchenote</span>
                  </div>
                  <div class="share-app"><div class="share-icon">📝</div><span>メモ</span></div>
                </div>
                <div class="share-actions">
                  <div class="share-action">リンクをコピー</div>
                  <div class="share-action">ブックマークに追加</div>
                </div>
              </div>
            </div>
          </PhoneMockup>
        </div>
        <div class="md:order-2">
          <div class="step-number">2</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Kitchenoteにシェア</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">共有ボタンをタップして、Kitchenoteを選ぶだけ。URLをコピペしてもOK。2秒で完了。</p>
          <div class="tip-box">共有シートからの方が速いですが、コピペでも問題なし。</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 3 -->
  <section class="step-section py-12 md:py-20 bg-white">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div>
          <div class="step-number">3</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">魔法を見届ける</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">ページを読み込み、必要な情報だけを抽出。タイトル、材料、手順、調理時間、写真。余計なものは一切なし。</p>
          <div class="tip-box">保存後はいつでも編集やメモの追加ができます。</div>
        </div>
        <div class="animate-on-scroll">
          <PhoneMockup>
            <div class="demo-extract">
              <div class="demo-kn-header"><span class="demo-kn-title">取り込み中...</span></div>
              <div class="extract-scene extract-scene-1">
                <div class="extract-progress"><div class="extract-progress-fill"></div></div>
                <div class="extract-status">ページを読み込み中...</div>
                <div class="extract-items">
                  <div class="extract-item ei-1"><span class="extract-check">✓</span> タイトルを検出</div>
                  <div class="extract-item ei-2"><span class="extract-check">✓</span> 材料12点</div>
                  <div class="extract-item ei-3"><span class="extract-check">✓</span> 手順6ステップ</div>
                  <div class="extract-item ei-4"><span class="extract-check">✓</span> 調理時間: 45分</div>
                  <div class="extract-item ei-5"><span class="extract-check">✓</span> 写真を保存</div>
                </div>
              </div>
              <div class="extract-scene extract-scene-2">
                <div class="extract-done-icon">✨</div>
                <div class="extract-done-text">レシピを保存しました！</div>
                <div class="extract-recipe-preview">
                  <div class="erp-img"></div>
                  <div class="erp-body">
                    <div class="erp-name">チキンティッカマサラ</div>
                    <div class="erp-meta">45分 · 4人分 · 材料12点</div>
                  </div>
                </div>
              </div>
            </div>
          </PhoneMockup>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 4 -->
  <section class="step-section py-12 md:py-20">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div class="animate-on-scroll md:order-1">
          <PhoneMockup>
            <div class="demo-final">
              <div class="demo-kn-header"><span class="demo-kn-title">マイレシピ</span></div>
              <div class="final-grid">
                <div class="final-card fc-1"><div class="final-thumb" style="background:linear-gradient(135deg,#f4a261,#e76f51);"></div><div class="final-info"><div class="final-name">ティッカマサラ</div><div class="final-time">45分</div></div></div>
                <div class="final-card fc-2"><div class="final-thumb" style="background:linear-gradient(135deg,#a8c686,#788d61);"></div><div class="final-info"><div class="final-name">シーザーサラダ</div><div class="final-time">15分</div></div></div>
                <div class="final-card fc-3"><div class="final-thumb" style="background:linear-gradient(135deg,#f2cc8f,#e4b363);"></div><div class="final-info"><div class="final-name">バナナブレッド</div><div class="final-time">60分</div></div></div>
                <div class="final-card fc-4"><div class="final-thumb" style="background:linear-gradient(135deg,#8ecae6,#6b8cce);"></div><div class="final-info"><div class="final-name">パッタイ</div><div class="final-time">30分</div></div></div>
                <div class="final-card fc-5"><div class="final-thumb" style="background:linear-gradient(135deg,#d97aab,#c45b8d);"></div><div class="final-info"><div class="final-name">ベリースムージー</div><div class="final-time">5分</div></div></div>
                <div class="final-card fc-6"><div class="final-thumb" style="background:linear-gradient(135deg,#b5838d,#9c6b73);"></div><div class="final-info"><div class="final-name">味噌汁</div><div class="final-time">20分</div></div></div>
              </div>
              <div class="final-cook-btn"><span>🍳</span> 料理を始める</div>
            </div>
          </PhoneMockup>
        </div>
        <div class="md:order-2">
          <div class="step-number">4</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">好きな時に料理する</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">レシピは保存・整理され、いつでも待機状態。クックモードを開けば大きな文字でステップ表示。邪魔なものは何もなし。</p>
          <div class="tip-box">すべてのレシピはオフラインで使えます。</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16">
    <div class="container-narrow">
      <h2 class="text-2xl font-display font-bold text-center mb-8">よくある質問</h2>
      <div class="space-y-4">
        <details class="group card">
          <summary class="flex items-center justify-between cursor-pointer list-none font-medium">レシピが正しくインポートできない場合は？<svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></summary>
          <p class="mt-3 text-neutral-600">まれに正しく読み込めない場合があります。手動で編集可能です。パーサーは常に改良中です。</p>
        </details>
        <details class="group card">
          <summary class="flex items-center justify-between cursor-pointer list-none font-medium">自分でレシピを作成できますか？<svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></summary>
          <p class="mt-3 text-neutral-600">もちろんです！ゼロから新しいレシピをいつでも作成できます。</p>
        </details>
        <details class="group card">
          <summary class="flex items-center justify-between cursor-pointer list-none font-medium">ログインが必要なサイトでも使えますか？<svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></summary>
          <p class="mt-3 text-neutral-600">ほとんどの場合はい。あなたがレシピを見られれば保存もできます。対応サイトは常に増やしています。</p>
        </details>
      </div>
      <p class="text-center mt-8"><a href="/ja/support" class="text-primary-600 hover:text-primary-700 font-medium">他の質問はこちら →</a></p>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-br from-primary-500 to-primary-600 text-white">
    <div class="container-narrow text-center">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-4 text-white">シンプルでしょう？</h2>
      <p class="text-primary-100 mb-8">リリース時にお知らせします。</p>
      <WaitlistForm />
    </div>
  </section>

</Layout>

<style>
  .step-number { width:48px;height:48px;border-radius:50%;background:#e86f4c;color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:20px;margin-bottom:16px;box-shadow:0 4px 16px rgba(232,111,76,0.25); }
  .tip-box { display:flex;align-items:center;gap:8px;padding:12px 16px;background:#f6f7f4;border-radius:10px;font-size:14px;color:#5d714a;border-left:3px solid #788d61; }
  .animate-on-scroll { opacity:0;transform:translateY(30px);transition:opacity 0.8s cubic-bezier(0.16,1,0.3,1),transform 0.8s cubic-bezier(0.16,1,0.3,1); }
  .animate-on-scroll.in-view { opacity:1;transform:translateY(0); }

  .demo-browse { width:100%;height:100%;display:flex;flex-direction:column; }
  .demo-safari-bar { padding:48px 12px 8px;background:#f2f2f7;display:flex;flex-direction:column;gap:6px; }
  .safari-dots { display:flex;gap:5px;padding:0 4px; }
  .dot { width:8px;height:8px;border-radius:50%;background:#d1d1d6; }
  .safari-url { background:white;border-radius:8px;padding:6px 10px;display:flex;align-items:center;gap:4px;font-size:12px; }
  .safari-lock { font-size:10px; } .safari-domain { color:#27272a;font-weight:500; }
  .demo-webpage { flex:1;padding:8px 12px;overflow:hidden; }
  .webpage-hero { height:72px;border-radius:8px;background:linear-gradient(135deg,#f4a261,#e76f51);margin-bottom:10px; }
  .webpage-title { font-size:14px;font-weight:700;color:#27272a;margin-bottom:3px; }
  .webpage-rating { font-size:10px;color:#f59e0b;margin-bottom:8px; }
  .webpage-text { height:8px;background:#e8e4de;border-radius:4px;margin-bottom:6px; }
  .line-1{width:100%}.line-2{width:85%}.line-3{width:92%}.line-4{width:78%}.line-5{width:88%}
  .webpage-ad { background:#fef0eb;color:#e86f4c;font-size:8px;font-weight:700;padding:8px;border-radius:6px;text-align:center;margin:8px 0;border:1px dashed #f4a261; }
  .webpage-scroll-hint { text-align:center;font-size:10px;color:#a1a1aa;margin-top:8px;animation:scrollHintPulse 2s ease-in-out infinite; }
  @keyframes scrollHintPulse { 0%,100%{opacity:0.4;transform:translateY(0)}50%{opacity:1;transform:translateY(3px)} }

  .demo-share { width:100%;height:100%;position:relative;background:#f2f2f7; }
  .share-backdrop { position:absolute;inset:0;background:rgba(0,0,0,0.3); }
  .share-sheet { position:absolute;bottom:0;left:0;right:0;background:white;border-radius:16px 16px 0 0;padding:12px 16px 24px;animation:sheetSlideUp 3s cubic-bezier(0.16,1,0.3,1) infinite; }
  @keyframes sheetSlideUp { 0%,10%{transform:translateY(100%)}25%,85%{transform:translateY(0)}95%,100%{transform:translateY(100%)} }
  .share-handle { width:36px;height:4px;background:#d1d1d6;border-radius:2px;margin:0 auto 12px; }
  .share-title { font-size:13px;font-weight:600;color:#27272a;margin-bottom:14px; }
  .share-apps { display:flex;gap:16px;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid #f0f0f0; }
  .share-app { display:flex;flex-direction:column;align-items:center;gap:4px;font-size:9px;color:#71717a; }
  .share-icon { width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;background:#f0f0f0; }
  .share-app-highlight .share-icon { background:transparent;animation:highlightPulse 3s ease-in-out infinite; }
  @keyframes highlightPulse { 0%,30%{box-shadow:0 0 0 2px transparent}45%,75%{box-shadow:0 0 0 2px #e86f4c,0 0 12px rgba(232,111,76,0.3)}90%,100%{box-shadow:0 0 0 2px transparent} }
  .share-app-highlight span { color:#e86f4c;font-weight:600; }
  .share-actions { display:flex;flex-direction:column;gap:1px; }
  .share-action { padding:10px;font-size:13px;color:#007aff;background:#f8f8fa;text-align:center; }
  .share-action:first-child{border-radius:10px 10px 0 0}.share-action:last-child{border-radius:0 0 10px 10px}

  .demo-extract { width:100%;height:100%;position:relative; }
  .demo-kn-header { padding:52px 18px 10px;text-align:center; }
  .demo-kn-title { font-size:16px;font-weight:700;color:#27272a; }
  .extract-scene { position:absolute;inset:0;top:78px;padding:16px 18px;display:flex;flex-direction:column;opacity:0; }
  .extract-scene-1 { animation:eScene1 8s ease-in-out infinite; }
  .extract-scene-2 { animation:eScene2 8s ease-in-out infinite;align-items:center;justify-content:center;top:0;padding-top:100px; }
  @keyframes eScene1 { 0%,5%{opacity:0}10%,55%{opacity:1}65%,100%{opacity:0} }
  @keyframes eScene2 { 0%,60%{opacity:0;transform:scale(0.95)}70%,90%{opacity:1;transform:scale(1)}98%,100%{opacity:0} }
  .extract-progress { height:4px;background:#f0ebe6;border-radius:2px;overflow:hidden;margin-bottom:12px; }
  .extract-progress-fill { height:100%;background:#e86f4c;border-radius:2px;animation:extractFill 8s ease-in-out infinite; }
  @keyframes extractFill { 0%,5%{width:0%}55%{width:100%}100%{width:100%} }
  .extract-status { font-size:12px;color:#71717a;margin-bottom:16px; }
  .extract-items { display:flex;flex-direction:column;gap:10px; }
  .extract-item { display:flex;align-items:center;gap:8px;font-size:13px;color:#27272a;opacity:0;transform:translateX(-8px);animation:extractItemIn 8s ease-out infinite; }
  .ei-1{animation-delay:0.5s}.ei-2{animation-delay:1.2s}.ei-3{animation-delay:1.9s}.ei-4{animation-delay:2.6s}.ei-5{animation-delay:3.3s}
  @keyframes extractItemIn { 0%,8%{opacity:0;transform:translateX(-8px)}14%,58%{opacity:1;transform:translateX(0)}65%,100%{opacity:0} }
  .extract-check { color:#788d61;font-weight:700; }
  .extract-done-icon { font-size:40px;margin-bottom:12px; }
  .extract-done-text { font-size:18px;font-weight:700;color:#27272a;margin-bottom:20px; }
  .extract-recipe-preview { background:white;border-radius:14px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,0.08);width:100%;max-width:200px; }
  .erp-img { height:72px;background:linear-gradient(135deg,#f4a261,#e76f51,#e86f4c); }
  .erp-body { padding:10px 12px; }
  .erp-name { font-size:13px;font-weight:700;color:#27272a;margin-bottom:2px; }
  .erp-meta { font-size:10px;color:#71717a; }

  .demo-final { width:100%;height:100%;position:relative; }
  .final-grid { display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:6px 14px; }
  .final-card { background:white;border-radius:10px;overflow:hidden;box-shadow:0 1px 6px rgba(0,0,0,0.05);opacity:0;animation:finalCardIn 1s cubic-bezier(0.16,1,0.3,1) forwards; }
  .fc-1{animation-delay:0.1s}.fc-2{animation-delay:0.2s}.fc-3{animation-delay:0.3s}.fc-4{animation-delay:0.4s}.fc-5{animation-delay:0.5s}.fc-6{animation-delay:0.6s}
  @keyframes finalCardIn { from{opacity:0;transform:translateY(10px) scale(0.95)}to{opacity:1;transform:translateY(0) scale(1)} }
  .final-thumb { height:48px; }
  .final-info { padding:6px 8px; }
  .final-name { font-size:10px;font-weight:600;color:#27272a; }
  .final-time { font-size:8px;color:#71717a; }
  .final-cook-btn { position:absolute;bottom:24px;left:50%;transform:translateX(-50%);background:#e86f4c;color:white;padding:10px 28px;border-radius:24px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:6px;box-shadow:0 4px 16px rgba(232,111,76,0.3);animation:cookBtnFloat 3s ease-in-out infinite; }
  @keyframes cookBtnFloat { 0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(-3px)} }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => { entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('in-view'); }); },
    { threshold: 0.2, rootMargin: '0px 0px -50px 0px' }
  );
  document.querySelectorAll('.animate-on-scroll').forEach((el) => observer.observe(el));
</script>
