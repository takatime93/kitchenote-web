---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/translations';

const t = useTranslations('ja');

const features = [
  {
    title: 'ワンタップ保存',
    description: "「この料理作りたい！」と思った瞬間を覚えていますか？でもレシピにたどり着くまでに、誰かのトスカーナ旅行記を3,000文字読まされた経験はありませんか？Kitchenoteなら、URLをシェアするだけ。材料、手順、写真だけを抽出します。余計な情報も、ポップアップも、自動再生動画も、一切なし。",
    icon: 'import',
    highlight: '95%のレシピサイトに対応'
  },
  {
    title: 'かしこく整理',
    description: "3ヶ月前に保存したあのパスタレシピ、どこにあるか覚えていますか？ブックマーク？スクショ？謎のPinterestボード？Kitchenoteなら、ちゃんと使える整理機能があります。コレクション（「平日夜の時短レシピ」とか「義理の両親を唸らせたい日」とか）、好きなようにタグ付け、ちゃんと機能する検索。",
    icon: 'organize',
    highlight: 'コレクション、タグ、即検索'
  },
  {
    title: 'クックモード',
    description: "生の鶏肉を触りながらスマホでレシピを見たこと、ありますよね？あれ、最悪ですよね。クックモードは、本物のキッチンの混乱を想定して設計されています。大きくて読みやすい文字。一度に1ステップずつ。画面は常にオン（小麦粉だらけの手でロック解除するあのイライラ、もうさよなら）。",
    icon: 'cook',
    highlight: 'ハンズフリーナビゲーション'
  },
  {
    title: 'かんたん分量調整',
    description: "レシピって大体4人分で書かれていますよね。でも2人分だったり、12人のディナーパーティーだったり、一週間分の作り置きだったり。人数をタップするだけで、全ての分量が自動で再計算されます。「2/3カップの3/4って何cc？」という暗算から解放されます。",
    icon: 'scale',
    highlight: '単位換算も自動'
  },
  {
    title: 'オフラインアクセス',
    description: "キッチンのWiFi、不安定じゃないですか？（うちは確実にそうです。）保存したレシピはすべてデバイスに保存されるので、ネットがなくても安心。料理中に「読み込み中...」なんて待たされる心配はありません。",
    icon: 'offline',
    highlight: 'ネット接続不要'
  },
  {
    title: '買い物リスト',
    description: "ワンタップで全材料を買い物リストに追加。買ったらチェックを外す。忘れ物があっても、リストはいつもポケットの中。同じ材料は自動でまとめられるので、2つのレシピに玉ねぎが必要なら「玉ねぎ4個」と表示されます。",
    icon: 'shopping',
    highlight: '材料を賢くまとめる'
  }
];

const iconPaths: Record<string, string> = {
  import: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />`,
  organize: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />`,
  cook: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  scale: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />`,
  offline: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />`,
  shopping: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />`
};
---

<Layout title="機能" description="Kitchenoteでレシピ管理がどれだけシンプルになるか、すべての機能をご紹介。ウェブサイトからのインポート、コレクション整理、クックモードなど。">

  <!-- Hero -->
  <section class="py-16 md:py-24">
    <div class="container-narrow text-center">
      <h1 class="mb-6">本当に必要な機能だけ</h1>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
        チェックボックスを埋めるために機能を作ったわけではありません。Kitchenoteのすべての機能は、家で料理する人が本当に抱えている問題を解決するために存在します。正直、私たちも他のアプリにうんざりしていたんです。
      </p>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="pb-20">
    <div class="container-wide">
      <div class="space-y-16">
        {features.map((feature, index) => (
          <div class:list={[
            "grid md:grid-cols-2 gap-8 md:gap-16 items-center",
            index % 2 === 1 && "md:flex-row-reverse"
          ]}>
            <!-- Content -->
            <div class:list={[index % 2 === 1 && "md:order-2"]}>
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 rounded-xl bg-primary-100 flex items-center justify-center">
                  <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <Fragment set:html={iconPaths[feature.icon]} />
                  </svg>
                </div>
                <h2 class="text-2xl md:text-3xl font-display font-bold">{feature.title}</h2>
              </div>
              <p class="text-neutral-600 leading-relaxed mb-4">
                {feature.description}
              </p>
              <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-sage-50 text-sage-700 text-sm font-medium">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {feature.highlight}
              </div>
            </div>

            <!-- Visual placeholder -->
            <div class:list={[
              "relative aspect-[4/3] rounded-2xl bg-gradient-to-br from-cream-100 to-cream-200 border border-cream-300 flex items-center justify-center",
              index % 2 === 1 && "md:order-1"
            ]}>
              <span class="text-neutral-400">機能イラスト</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary-50 border-y border-primary-100">
    <div class="container-narrow text-center">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">
        レシピの混乱、整理しませんか？
      </h2>
      <p class="text-neutral-600 mb-8">
        やっと使える仕組みを見つけた料理好きの仲間入りを。
      </p>
      <a href="#download" class="btn-primary">
        Kitchenoteを無料でダウンロード
      </a>
    </div>
  </section>

</Layout>
