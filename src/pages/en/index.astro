---
import Layout from '../../layouts/Layout.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import StepCard from '../../components/StepCard.astro';
import PhoneMockup from '../../components/PhoneMockup.astro';
import WaitlistForm from '../../components/WaitlistForm.astro';
import { useTranslations } from '../../i18n/translations';

const t = useTranslations('en');

const features = [
  { icon: 'import' as const, titleKey: 'features.import.title', descKey: 'features.import.desc' },
  { icon: 'organize' as const, titleKey: 'features.organize.title', descKey: 'features.organize.desc' },
  { icon: 'cook' as const, titleKey: 'features.cook.title', descKey: 'features.cook.desc' },
  { icon: 'scale' as const, titleKey: 'features.scale.title', descKey: 'features.scale.desc' },
];

const painPoints = [
  { emoji: '🔖', text: t('pain.bookmark') },
  { emoji: '📜', text: t('pain.scroll') },
  { emoji: '📸', text: t('pain.screenshots') },
  { emoji: '🌐', text: t('pain.tabs') },
];
---

<Layout title="Home" description="Save recipes from any website. Organize, scale, and cook with ease. Kitchenote is the recipe manager that gets out of your way.">

  <!-- Hero Section -->
  <section class="py-16 md:py-24 overflow-hidden">
    <div class="container-wide">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="max-w-xl">
          <p class="text-primary-600 font-display font-semibold mb-4">
            {t('hero.tagline')}
          </p>
          <h1 class="text-balance mb-6">
            {t('hero.headline')}
          </h1>
          <p class="text-lg text-neutral-600 mb-8 leading-relaxed">
            {t('hero.subheadline')}
          </p>
          <div class="max-w-md">
            <WaitlistForm />
          </div>
        </div>

        <!-- Animated App Preview -->
        <div class="hero-phone-wrapper animate-on-scroll">
          <PhoneMockup>
            <div class="hero-demo">
              <div class="hero-app-bar">
                <span class="hero-app-title">Kitchenote</span>
              </div>

              <!-- Scene 1: URL input -->
              <div class="hero-scene hero-scene-1">
                <div class="hero-input-label">Paste a recipe URL</div>
                <div class="hero-url-field">
                  <span class="hero-typing">cookpad.com/recipe/7654321</span>
                  <span class="hero-cursor"></span>
                </div>
                <div class="hero-import-btn">Import Recipe</div>
              </div>

              <!-- Scene 2: Loading -->
              <div class="hero-scene hero-scene-2">
                <div class="hero-loader-ring"></div>
                <div class="hero-loader-text">Extracting recipe...</div>
              </div>

              <!-- Scene 3: Clean recipe -->
              <div class="hero-scene hero-scene-3">
                <div class="hero-recipe">
                  <div class="hero-recipe-img"></div>
                  <div class="hero-recipe-content">
                    <div class="hero-recipe-title">Chicken Tikka Masala</div>
                    <div class="hero-recipe-meta">🕐 45 min · 👤 4 servings</div>
                    <div class="hero-recipe-divider"></div>
                    <div class="hero-ingredient">500g chicken thigh</div>
                    <div class="hero-ingredient">1 cup yogurt</div>
                    <div class="hero-ingredient">2 tbsp garam masala</div>
                  </div>
                </div>
              </div>
            </div>
          </PhoneMockup>
        </div>
      </div>
    </div>
  </section>

  <!-- Pain Points Section -->
  <section class="py-16 bg-white">
    <div class="container-wide">
      <h2 class="section-title">{t('pain.title')}</h2>
      <p class="section-subtitle">{t('pain.subtitle')}</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {painPoints.map(({ emoji, text }) => (
          <div class="flex items-start gap-4 p-4 rounded-xl bg-cream-50 border border-cream-200">
            <span class="text-2xl">{emoji}</span>
            <p class="text-neutral-700">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20">
    <div class="container-wide">
      <h2 class="section-title">{t('features.title')}</h2>
      <p class="section-subtitle">{t('features.subtitle')}</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map(({ icon, titleKey, descKey }) => (
          <FeatureCard
            icon={icon}
            title={t(titleKey)}
            description={t(descKey)}
          />
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/en/features" class="btn-secondary">
          See all features →
        </a>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="py-20 bg-white">
    <div class="container-narrow">
      <h2 class="section-title">{t('how.title')}</h2>
      <p class="section-subtitle">{t('how.subtitle')}</p>

      <div class="space-y-8 md:space-y-12 pl-4">
        <StepCard
          number={1}
          title={t('how.step1.title')}
          description={t('how.step1.desc')}
        />
        <StepCard
          number={2}
          title={t('how.step2.title')}
          description={t('how.step2.desc')}
        />
        <StepCard
          number={3}
          title={t('how.step3.title')}
          description={t('how.step3.desc')}
        />
      </div>
    </div>
  </section>

  <!-- Differentiators Section -->
  <section class="py-20">
    <div class="container-wide">
      <h2 class="section-title">{t('diff.title')}</h2>
      <p class="section-subtitle">{t('diff.subtitle')}</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="card p-6 border-l-4 border-l-primary-400">
          <h3 class="font-display font-bold text-lg mb-2">{t('diff.offline.title')}</h3>
          <p class="text-neutral-600 text-sm">{t('diff.offline.desc')}</p>
        </div>
        <div class="card p-6 border-l-4 border-l-sage-400">
          <h3 class="font-display font-bold text-lg mb-2">{t('diff.units.title')}</h3>
          <p class="text-neutral-600 text-sm">{t('diff.units.desc')}</p>
        </div>
        <div class="card p-6 border-l-4 border-l-primary-400">
          <h3 class="font-display font-bold text-lg mb-2">{t('diff.ocr.title')}</h3>
          <p class="text-neutral-600 text-sm">{t('diff.ocr.desc')}</p>
        </div>
        <div class="card p-6 border-l-4 border-l-sage-400">
          <h3 class="font-display font-bold text-lg mb-2">{t('diff.versions.title')}</h3>
          <p class="text-neutral-600 text-sm">{t('diff.versions.desc')}</p>
        </div>
        <div class="card p-6 border-l-4 border-l-primary-400">
          <h3 class="font-display font-bold text-lg mb-2">{t('diff.focus.title')}</h3>
          <p class="text-neutral-600 text-sm">{t('diff.focus.desc')}</p>
        </div>
        <div class="card p-6 border-l-4 border-l-sage-400">
          <h3 class="font-display font-bold text-lg mb-2">{t('diff.free.title')}</h3>
          <p class="text-neutral-600 text-sm">{t('diff.free.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- International Support -->
  <section class="py-20 bg-white">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="section-title">{t('intl.title')}</h2>
        <p class="section-subtitle">{t('intl.subtitle')}</p>

        <div class="flex flex-wrap justify-center gap-4">
          <div class="flex items-center gap-3 px-6 py-3 rounded-full bg-cream-100 border border-cream-200">
            <span class="text-2xl">🇺🇸</span>
            <span class="font-medium text-neutral-700">{t('intl.en')}</span>
          </div>
          <div class="flex items-center gap-3 px-6 py-3 rounded-full bg-cream-100 border border-cream-200">
            <span class="text-2xl">🇯🇵</span>
            <span class="font-medium text-neutral-700">{t('intl.ja')}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <section id="download" class="py-20 bg-gradient-to-br from-primary-500 to-primary-600 text-white">
    <div class="container-narrow text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4 text-white">
        Be the first to know
      </h2>
      <p class="text-lg text-primary-100 mb-8 max-w-xl mx-auto">
        Kitchenote is almost ready. Join the waitlist and we'll let you know the moment it launches.
      </p>
      <WaitlistForm />
    </div>
  </section>

</Layout>

<style>
  /* ========================================= */
  /*  Hero phone animation                     */
  /* ========================================= */

  .hero-phone-wrapper {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-phone-wrapper.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  .hero-demo {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .hero-app-bar {
    padding: 52px 18px 12px;
    text-align: center;
  }

  .hero-app-title {
    font-size: 16px;
    font-weight: 700;
    color: #27272a;
  }

  .hero-scene {
    position: absolute;
    inset: 0;
    top: 78px;
    padding: 12px 18px;
    display: flex;
    flex-direction: column;
    opacity: 0;
  }

  .hero-scene-1 {
    animation: heroS1 9s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  .hero-scene-2 {
    animation: heroS2 9s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    align-items: center;
    justify-content: center;
    top: 0;
    padding-top: 120px;
  }

  .hero-scene-3 {
    animation: heroS3 9s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes heroS1 {
    0%    { opacity: 0; transform: translateY(8px); }
    5%    { opacity: 1; transform: translateY(0); }
    35%   { opacity: 1; }
    42%   { opacity: 0; transform: translateY(-8px); }
    100%  { opacity: 0; }
  }

  @keyframes heroS2 {
    0%, 38% { opacity: 0; }
    45%     { opacity: 1; }
    58%     { opacity: 1; }
    65%     { opacity: 0; }
    100%    { opacity: 0; }
  }

  @keyframes heroS3 {
    0%, 60% { opacity: 0; transform: translateY(16px); }
    68%     { opacity: 1; transform: translateY(0); }
    92%     { opacity: 1; }
    98%     { opacity: 0; }
    100%    { opacity: 0; }
  }

  .hero-input-label {
    font-size: 13px;
    color: #71717a;
    margin-bottom: 10px;
  }

  .hero-url-field {
    background: white;
    border: 1.5px solid #e8e4de;
    border-radius: 10px;
    padding: 12px 14px;
    display: flex;
    align-items: center;
    margin-bottom: 16px;
    overflow: hidden;
  }

  .hero-typing {
    font-size: 12px;
    color: #27272a;
    white-space: nowrap;
    overflow: hidden;
    max-width: 0;
    display: inline-block;
    animation: heroType 9s infinite;
  }

  @keyframes heroType {
    0%, 5%  { max-width: 0; }
    28%     { max-width: 220px; }
    42%     { max-width: 220px; }
    100%    { max-width: 220px; }
  }

  .hero-cursor {
    width: 2px;
    height: 14px;
    background: #e86f4c;
    flex-shrink: 0;
    animation: heroBlink 0.6s step-end infinite;
  }

  @keyframes heroBlink {
    50% { opacity: 0; }
  }

  .hero-import-btn {
    background: #e86f4c;
    color: white;
    text-align: center;
    padding: 12px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
  }

  .hero-loader-ring {
    width: 40px;
    height: 40px;
    border: 3px solid #f0ebe6;
    border-top-color: #e86f4c;
    border-radius: 50%;
    animation: heroSpin 0.8s linear infinite;
    margin-bottom: 12px;
  }

  @keyframes heroSpin {
    to { transform: rotate(360deg); }
  }

  .hero-loader-text {
    font-size: 13px;
    color: #71717a;
    animation: heroPulse 1.5s ease-in-out infinite;
  }

  @keyframes heroPulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  .hero-recipe {
    background: white;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .hero-recipe-img {
    height: 96px;
    background: url('/images/recipes/tikka-masala.jpg') center/cover;
  }

  .hero-recipe-content {
    padding: 12px 14px;
  }

  .hero-recipe-title {
    font-size: 15px;
    font-weight: 700;
    color: #27272a;
    margin-bottom: 4px;
  }

  .hero-recipe-meta {
    font-size: 11px;
    color: #71717a;
    margin-bottom: 8px;
  }

  .hero-recipe-divider {
    height: 1px;
    background: #f0ebe6;
    margin-bottom: 6px;
  }

  .hero-ingredient {
    font-size: 12px;
    color: #52525b;
    padding: 3px 0;
    border-bottom: 1px solid #faf6f1;
    opacity: 0;
    animation: heroIngredient 9s infinite;
  }

  .hero-ingredient:nth-child(1) { animation-delay: 0.1s; }
  .hero-ingredient:nth-child(2) { animation-delay: 0.2s; }
  .hero-ingredient:nth-child(3) { animation-delay: 0.3s; }

  @keyframes heroIngredient {
    0%, 65%  { opacity: 0; transform: translateY(6px); }
    72%      { opacity: 1; transform: translateY(0); }
    92%      { opacity: 1; }
    98%      { opacity: 0; }
    100%     { opacity: 0; }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
        }
      });
    },
    { threshold: 0.2, rootMargin: '0px 0px -50px 0px' }
  );

  document.querySelectorAll('.animate-on-scroll, .hero-phone-wrapper').forEach((el) => {
    observer.observe(el);
  });
</script>
