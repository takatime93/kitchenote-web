---
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/translations';

const t = useTranslations('en');

// Sample blog posts - in production, these would come from content collections
const posts = [
  {
    slug: 'why-recipe-websites-are-so-annoying',
    title: 'Why recipe websites are so annoying (and what we\'re doing about it)',
    excerpt: 'You just want to make cookies. You don\'t need 2,000 words about someone\'s grandmother. Here\'s why food blogs are the way they are, and how Kitchenote fixes it.',
    date: '2024-01-15',
    readTime: '4 min read',
    category: 'Thoughts'
  },
  {
    slug: 'scaling-recipes-the-right-way',
    title: 'Scaling recipes: It\'s not always just math',
    excerpt: 'Double the ingredients doesn\'t always mean double everything. Here\'s what you need to know about scaling recipes up (or down) without ruining your dish.',
    date: '2024-01-10',
    readTime: '5 min read',
    category: 'Tips'
  },
  {
    slug: 'organize-your-recipe-collection',
    title: '5 ways to organize your recipe collection (that actually work)',
    excerpt: 'Folders? Tags? Collections? Here\'s a practical guide to organizing recipes in a way that helps you find what you want, when you want it.',
    date: '2024-01-05',
    readTime: '3 min read',
    category: 'Tips'
  }
];

function formatDate(dateString: string): string {
  return new Date(dateString).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<Layout title="Blog" description="Tips, recipes, and thoughts on cooking from home. The Kitchenote blog.">

  <!-- Hero -->
  <section class="py-16 md:py-24">
    <div class="container-narrow text-center">
      <h1 class="mb-4">{t('blog.title')}</h1>
      <p class="text-lg text-neutral-600">
        {t('blog.subtitle')}
      </p>
    </div>
  </section>

  <!-- Posts -->
  <section class="pb-20">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <article class="card group hover:border-primary-200 transition-all duration-300">
            <!-- Category badge -->
            <div class="mb-4">
              <span class="inline-block px-3 py-1 text-xs font-medium text-sage-700 bg-sage-50 rounded-full">
                {post.category}
              </span>
            </div>

            <!-- Title -->
            <h2 class="text-xl font-display font-bold mb-3 group-hover:text-primary-600 transition-colors">
              <a href={`/en/blog/${post.slug}`} class="hover:text-primary-600">
                {post.title}
              </a>
            </h2>

            <!-- Excerpt -->
            <p class="text-neutral-600 text-sm leading-relaxed mb-4">
              {post.excerpt}
            </p>

            <!-- Meta -->
            <div class="flex items-center justify-between text-sm text-neutral-500">
              <time datetime={post.date}>{formatDate(post.date)}</time>
              <span>{post.readTime}</span>
            </div>

            <!-- Read more link -->
            <a
              href={`/en/blog/${post.slug}`}
              class="inline-flex items-center gap-1 mt-4 text-primary-600 hover:text-primary-700 font-medium text-sm"
            >
              {t('blog.readMore')}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter signup -->
  <section class="py-16 bg-white">
    <div class="container-narrow text-center">
      <h2 class="text-2xl font-display font-bold mb-4">
        Get cooking tips in your inbox
      </h2>
      <p class="text-neutral-600 mb-6">
        Occasional emails about recipes, cooking tips, and Kitchenote updates. No spam, unsubscribe anytime.
      </p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          placeholder="your@email.com"
          class="flex-1 px-4 py-3 rounded-full border border-cream-300 focus:outline-none focus:border-primary-400 focus:ring-2 focus:ring-primary-100"
          required
        />
        <button type="submit" class="btn-primary">
          Subscribe
        </button>
      </form>
      <p class="text-xs text-neutral-500 mt-4">
        We respect your privacy. See our <a href="/en/privacy" class="underline">Privacy Policy</a>.
      </p>
    </div>
  </section>

</Layout>
