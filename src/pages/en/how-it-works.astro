---
import Layout from '../../layouts/Layout.astro';
import PhoneMockup from '../../components/PhoneMockup.astro';
import WaitlistForm from '../../components/WaitlistForm.astro';
---

<Layout title="How It Works" description="Learn how Kitchenote makes saving, sharing, and cooking recipes effortless. Import from any site, collaborate with family, and get AI-powered help.">

  <!-- Hero -->
  <section class="py-12 md:py-20">
    <div class="container-narrow text-center">
      <h1 class="mb-4">How Kitchenote works</h1>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
        Everything you need to save, share, and cook recipes — in one app.
      </p>
    </div>
  </section>

  <!-- Tab Bar -->
  <div class="tab-bar-wrapper">
    <div class="container-wide">
      <div class="tab-bar">
        <button class="tab-btn tab-active" data-tab="import">
          <span class="tab-icon">📥</span>
          <span class="tab-label">Save & Cook</span>
        </button>
        <button class="tab-btn" data-tab="sharing">
          <span class="tab-icon">👨‍👩‍👧‍👦</span>
          <span class="tab-label">Share & Collaborate</span>
        </button>
        <button class="tab-btn" data-tab="ai">
          <span class="tab-icon">✨</span>
          <span class="tab-label">AI Assistant</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ============================================ -->
  <!--  TAB 1: SAVE & COOK                         -->
  <!-- ============================================ -->
  <div class="tab-panel tab-panel-active" id="panel-import">

    <!-- Step 1: Find -->
    <section class="py-12 md:py-20 bg-white">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div>
            <div class="step-number">1</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Find a recipe you love</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              Could be anywhere — your favorite food blog, a YouTube video, or a recipe your grandmother texted you. If it's on the web, Kitchenote can save it.
            </p>
            <div class="tip-box">Works with 95% of recipe sites, including protected ones.</div>
          </div>
          <div class="animate-on-scroll">
            <PhoneMockup>
              <div class="demo-browse">
                <div class="demo-safari-bar">
                  <div class="safari-dots"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>
                  <div class="safari-url"><span class="safari-lock">🔒</span><span class="safari-domain">allrecipes.com</span></div>
                </div>
                <div class="demo-webpage">
                  <div class="webpage-hero"></div>
                  <div class="webpage-title">Chicken Tikka Masala</div>
                  <div class="webpage-rating">★★★★★ 4.8 (2,340 reviews)</div>
                  <div class="webpage-text line-1"></div><div class="webpage-text line-2"></div><div class="webpage-text line-3"></div>
                  <div class="webpage-ad">ADVERTISEMENT</div>
                  <div class="webpage-text line-4"></div><div class="webpage-text line-5"></div>
                  <div class="webpage-inline-img"></div>
                  <div class="webpage-text line-1"></div><div class="webpage-text line-2"></div>
                  <div class="webpage-ad">SPONSORED</div>
                  <div class="webpage-text line-3"></div><div class="webpage-text line-4"></div>
                </div>
              </div>
            </PhoneMockup>
          </div>
        </div>
      </div>
    </section>

    <!-- Step 2: Share -->
    <section class="py-12 md:py-20">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div class="animate-on-scroll md:order-1">
            <PhoneMockup>
              <div class="demo-share">
                <div class="share-backdrop"></div>
                <div class="share-sheet">
                  <div class="share-handle"></div>
                  <div class="share-title">Share to...</div>
                  <div class="share-apps">
                    <div class="share-app"><div class="share-icon">💬</div><span>Messages</span></div>
                    <div class="share-app"><div class="share-icon">✉️</div><span>Mail</span></div>
                    <div class="share-app share-app-highlight">
                      <div class="share-icon icon-kn"><svg width="18" height="18" viewBox="0 0 32 32" fill="none"><rect width="32" height="32" rx="8" fill="#e86f4c"/><path d="M8 10h16M8 16h12M8 22h8" stroke="white" stroke-width="2.5" stroke-linecap="round"/></svg></div>
                      <span>Kitchenote</span>
                    </div>
                    <div class="share-app"><div class="share-icon">📝</div><span>Notes</span></div>
                  </div>
                  <div class="share-actions"><div class="share-action">Copy Link</div><div class="share-action">Add Bookmark</div></div>
                </div>
              </div>
            </PhoneMockup>
          </div>
          <div class="md:order-2">
            <div class="step-number">2</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Share it to Kitchenote</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              Hit the share button and pick Kitchenote from the list. Or just paste the URL. About two seconds.
            </p>
            <div class="tip-box">Share sheet is fastest, but copy-paste works great too.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Step 3: Extract -->
    <section class="py-12 md:py-20 bg-white">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div>
            <div class="step-number">3</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Watch the magic happen</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              Kitchenote reads the page and pulls out exactly what matters — title, ingredients, instructions, cook time, and photos.
            </p>
            <div class="tip-box">You can always edit or add notes after saving.</div>
          </div>
          <div class="animate-on-scroll">
            <PhoneMockup>
              <div class="demo-extract">
                <div class="demo-kn-header"><span class="demo-kn-title">Importing...</span></div>
                <div class="extract-content">
                  <div class="extract-progress"><div class="extract-progress-fill"></div></div>
                  <div class="extract-status">Reading page...</div>
                  <div class="extract-items">
                    <div class="extract-item ei-1"><span class="extract-check">✓</span> Title found</div>
                    <div class="extract-item ei-2"><span class="extract-check">✓</span> 12 ingredients</div>
                    <div class="extract-item ei-3"><span class="extract-check">✓</span> 6 steps</div>
                    <div class="extract-item ei-4"><span class="extract-check">✓</span> Cook time: 45 min</div>
                    <div class="extract-item ei-5"><span class="extract-check">✓</span> Photo saved</div>
                  </div>
                  <div class="extract-done"><div class="extract-done-icon">✨</div><div class="extract-done-text">Recipe saved!</div></div>
                </div>
              </div>
            </PhoneMockup>
          </div>
        </div>
      </div>
    </section>

    <!-- Comparison: Website vs App -->
    <section class="py-12 md:py-20">
      <div class="container-wide">
        <div class="text-center mb-12">
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">See the difference</h2>
          <p class="text-neutral-600">Same recipe. Completely different experience.</p>
        </div>
        <div class="comparison animate-on-scroll">
          <div class="comparison-grid">
            <div class="compare-side">
              <div class="compare-label compare-label-bad">Recipe website</div>
              <PhoneMockup>
                <div class="web-mess">
                  <div class="web-mess-bar"><div class="web-mess-dots"><span></span><span></span><span></span></div><div class="web-mess-url">foodblog.com/best-ever-tikka</div></div>
                  <div class="web-mess-content">
                    <div class="web-mess-popup"><div class="popup-x">✕</div><div class="popup-text">Subscribe for FREE recipes!</div><div class="popup-input"></div></div>
                    <div class="web-mess-hero-img"></div>
                    <div class="web-mess-title">The BEST Chicken Tikka Masala You'll Ever Make!</div>
                    <div class="web-mess-meta">By Jessica · March 2025 · 847 comments</div>
                    <div class="web-mess-story"><div class="wm-line" style="width:100%"></div><div class="wm-line" style="width:92%"></div><div class="wm-line" style="width:88%"></div></div>
                    <div class="web-mess-ad">ADVERTISEMENT</div>
                    <div class="web-mess-story"><div class="wm-line" style="width:95%"></div><div class="wm-line" style="width:85%"></div><div class="wm-line" style="width:90%"></div></div>
                    <div class="web-mess-inline-img"></div>
                    <div class="web-mess-ad">SPONSORED</div>
                    <div class="web-mess-story"><div class="wm-line" style="width:92%"></div><div class="wm-line" style="width:80%"></div></div>
                  </div>
                </div>
              </PhoneMockup>
              <div class="compare-list"><div class="issue">❌ 2,000-word life story</div><div class="issue">❌ Pop-ups and ads</div><div class="issue">❌ Needs internet</div><div class="issue">❌ Can't scale servings</div></div>
            </div>
            <div class="compare-side">
              <div class="compare-label compare-label-good">In Kitchenote</div>
              <PhoneMockup>
                <div class="app-clean">
                  <div class="app-clean-header"><span class="app-clean-back">‹</span><span class="app-clean-title">Chicken Tikka Masala</span><span class="app-clean-edit">✎</span></div>
                  <div class="app-clean-img"></div>
                  <div class="app-clean-body">
                    <div class="app-clean-name">Chicken Tikka Masala</div>
                    <div class="app-clean-meta-row"><span class="app-meta-pill">🕐 45 min</span><span class="app-meta-pill">👤 4 servings</span><span class="app-meta-pill">⭐ Saved</span></div>
                    <div class="app-clean-section-title">Ingredients</div>
                    <div class="app-clean-ing"><span class="ing-qty">500g</span> chicken thigh</div>
                    <div class="app-clean-ing"><span class="ing-qty">1 cup</span> yogurt</div>
                    <div class="app-clean-ing"><span class="ing-qty">2 tbsp</span> garam masala</div>
                    <div class="app-clean-ing"><span class="ing-qty">400g</span> crushed tomatoes</div>
                    <div class="app-clean-ing"><span class="ing-qty">1 tbsp</span> olive oil</div>
                    <div class="app-clean-section-title">Steps</div>
                    <div class="app-clean-step"><span class="step-num-sm">1</span> Marinate chicken in yogurt and spices for 30 min</div>
                    <div class="app-clean-step"><span class="step-num-sm">2</span> Heat oil, cook chicken until golden</div>
                  </div>
                  <div class="app-clean-cook-btn">🍳 Start Cook Mode</div>
                </div>
              </PhoneMockup>
              <div class="compare-list"><div class="win">✅ Just the recipe</div><div class="win">✅ No ads, no pop-ups</div><div class="win">✅ Works offline</div><div class="win">✅ Scale to any serving size</div></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Step 4: Cook -->
    <section class="py-12 md:py-20 bg-white">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div class="animate-on-scroll md:order-1">
            <PhoneMockup>
              <div class="demo-final">
                <div class="demo-kn-header"><span class="demo-kn-title">My Recipes</span></div>
                <div class="final-grid">
                  <div class="final-card fc-1"><div class="final-thumb" style="background:url('/images/recipes/tikka-masala.jpg') center/cover;"></div><div class="final-info"><div class="final-name">Tikka Masala</div><div class="final-time">45 min</div></div></div>
                  <div class="final-card fc-2"><div class="final-thumb" style="background:url('/images/recipes/caesar-salad.jpg') center/cover;"></div><div class="final-info"><div class="final-name">Caesar Salad</div><div class="final-time">15 min</div></div></div>
                  <div class="final-card fc-3"><div class="final-thumb" style="background:url('/images/recipes/banana-bread.jpg') center/cover;"></div><div class="final-info"><div class="final-name">Banana Bread</div><div class="final-time">60 min</div></div></div>
                  <div class="final-card fc-4"><div class="final-thumb" style="background:url('/images/recipes/pad-thai.jpg') center/cover;"></div><div class="final-info"><div class="final-name">Pad Thai</div><div class="final-time">30 min</div></div></div>
                  <div class="final-card fc-5"><div class="final-thumb" style="background:url('/images/recipes/berry-smoothie.jpg') center/cover;"></div><div class="final-info"><div class="final-name">Berry Smoothie</div><div class="final-time">5 min</div></div></div>
                  <div class="final-card fc-6"><div class="final-thumb" style="background:url('/images/recipes/miso-soup.jpg') center/cover;"></div><div class="final-info"><div class="final-name">Miso Soup</div><div class="final-time">20 min</div></div></div>
                </div>
                <div class="final-cook-btn"><span>🍳</span> Start Cooking</div>
              </div>
            </PhoneMockup>
          </div>
          <div class="md:order-2">
            <div class="step-number">4</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Cook whenever you're ready</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              Your recipes are saved, organized, and waiting. Open Cook Mode for big text, step-by-step, no distractions.
            </p>
            <div class="tip-box">All recipes work offline. No WiFi needed.</div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- ============================================ -->
  <!--  TAB 2: SHARE & COLLABORATE                  -->
  <!-- ============================================ -->
  <div class="tab-panel" id="panel-sharing">

    <!-- Shared Cookbooks -->
    <section class="py-12 md:py-20 bg-white">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div>
            <div class="feature-emoji">📖</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Shared cookbooks</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              Create a shared cookbook with your partner, family, or friends. Everyone can add recipes, leave notes, and see updates in real time. Like a family recipe binder that lives in everyone's pocket.
            </p>
            <div class="tip-box">Free users get 2 shared cookbooks. Premium gets unlimited.</div>
          </div>
          <div class="animate-on-scroll">
            <div class="collab-visual">
              <div class="collab-cookbook">
                <div class="collab-book-icon">📖</div>
                <div class="collab-book-info"><div class="collab-book-name">Family Favorites</div><div class="collab-book-count">23 recipes</div></div>
                <div class="collab-avatars"><div class="c-avatar ca-1">Y</div><div class="c-avatar ca-2">T</div><div class="c-avatar ca-3">M</div><div class="c-avatar ca-4">+2</div></div>
              </div>
              <div class="collab-feed">
                <div class="collab-notif cn-1 animate-on-scroll"><div class="c-avatar ca-small ca-mom">M</div><div class="cn-content"><div class="cn-text"><strong>Mom</strong> added <em>Grandma's Apple Pie</em></div><div class="cn-time">2 min ago</div></div></div>
                <div class="collab-notif cn-2 animate-on-scroll"><div class="c-avatar ca-small ca-dad">D</div><div class="cn-content"><div class="cn-text"><strong>Dad</strong> commented "Try adding cinnamon!"</div><div class="cn-time">15 min ago</div></div></div>
                <div class="collab-notif cn-3 animate-on-scroll"><div class="c-avatar ca-small ca-sis">S</div><div class="cn-content"><div class="cn-text"><strong>Sarah</strong> saved your Pad Thai recipe</div><div class="cn-time">1 hr ago</div></div></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Versioning -->
    <section class="py-12 md:py-20">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div class="animate-on-scroll md:order-1">
            <div class="version-visual">
              <div class="ver-card ver-original">
                <div class="ver-badge ver-badge-original">Original</div>
                <div class="ver-img" style="background:url('/images/recipes/tikka-masala.jpg') center/cover;"></div>
                <div class="ver-body"><div class="ver-name">Mom's Curry</div><div class="ver-detail"><div class="ver-ing">2 tbsp mild curry powder</div><div class="ver-ing">1 cup coconut milk</div><div class="ver-ing">400g chicken breast</div></div></div>
              </div>
              <div class="ver-fork-arrow"><svg width="40" height="40" viewBox="0 0 40 40" fill="none"><path d="M12 20h16M22 14l6 6-6 6" stroke="#e86f4c" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
              <div class="ver-card ver-yours">
                <div class="ver-badge ver-badge-yours">Your Version</div>
                <div class="ver-img" style="background:url('/images/recipes/tikka-masala.jpg') center/cover;filter:hue-rotate(15deg) saturate(1.2);"></div>
                <div class="ver-body"><div class="ver-name">Extra Spicy Curry 🔥</div><div class="ver-detail"><div class="ver-ing ver-changed"><span class="ver-strike">2 tbsp mild</span> → 3 tbsp hot curry</div><div class="ver-ing">1 cup coconut milk</div><div class="ver-ing ver-changed"><span class="ver-strike">chicken breast</span> → thigh</div><div class="ver-ing ver-added">+ 2 Thai chilies</div></div></div>
              </div>
            </div>
          </div>
          <div class="md:order-2">
            <div class="feature-emoji">✏️</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Fork it. Make it yours.</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              Someone shared a great recipe but you like it spicier? Fork it. Swap ingredients, adjust amounts, add notes — without changing the original. Your version, their version, everyone's happy.
            </p>
            <div class="tip-box">Comments let you share what worked: "Added extra garlic, game changer."</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Friends & Activity -->
    <section class="py-12 md:py-20 bg-white">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div>
            <div class="feature-emoji">👥</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Follow the cooks you love</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              Add friends and family. See what they're saving, get inspired by their recipes, and build a shared food culture. When someone adds a recipe you'll love, you'll know.
            </p>
            <div class="tip-box">Friends & social features are free for everyone.</div>
          </div>
          <div class="animate-on-scroll">
            <div class="friends-visual">
              <div class="friend-profile fp-1 animate-on-scroll">
                <div class="c-avatar ca-small ca-mom">M</div>
                <div class="fp-info"><div class="fp-name">Mom</div><div class="fp-stat">47 recipes · 3 cookbooks</div></div>
                <div class="fp-follow fp-following">Following</div>
              </div>
              <div class="friend-profile fp-2 animate-on-scroll">
                <div class="c-avatar ca-small ca-dad">D</div>
                <div class="fp-info"><div class="fp-name">Dad</div><div class="fp-stat">12 recipes · BBQ master</div></div>
                <div class="fp-follow fp-following">Following</div>
              </div>
              <div class="friend-profile fp-3 animate-on-scroll">
                <div class="c-avatar ca-small ca-sis">S</div>
                <div class="fp-info"><div class="fp-name">Sarah</div><div class="fp-stat">31 recipes · Baking queen</div></div>
                <div class="fp-follow fp-following">Following</div>
              </div>
              <div class="friend-profile fp-4 animate-on-scroll">
                <div class="c-avatar ca-small" style="background:#8ecae6;">K</div>
                <div class="fp-info"><div class="fp-name">Kenji</div><div class="fp-stat">89 recipes · Japanese cuisine</div></div>
                <div class="fp-follow fp-add">+ Follow</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Notifications -->
    <section class="py-12 md:py-20">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div class="animate-on-scroll md:order-1">
            <div class="notif-visual">
              <div class="notif-header">Activity</div>
              <div class="notif-item ni-1 animate-on-scroll">
                <div class="notif-dot notif-dot-new"></div>
                <div class="c-avatar ca-small ca-mom">M</div>
                <div class="notif-body"><strong>Mom</strong> added <em>Grandma's Apple Pie</em> to Family Favorites</div>
                <div class="notif-time">2m</div>
              </div>
              <div class="notif-item ni-2 animate-on-scroll">
                <div class="notif-dot notif-dot-new"></div>
                <div class="c-avatar ca-small ca-sis">S</div>
                <div class="notif-body"><strong>Sarah</strong> commented on your <em>Banana Bread</em></div>
                <div class="notif-time">1h</div>
              </div>
              <div class="notif-item ni-3 animate-on-scroll">
                <div class="notif-dot"></div>
                <div class="c-avatar ca-small ca-dad">D</div>
                <div class="notif-body"><strong>Dad</strong> forked your <em>Curry</em> recipe</div>
                <div class="notif-time">3h</div>
              </div>
              <div class="notif-item ni-4 animate-on-scroll">
                <div class="notif-dot"></div>
                <div class="c-avatar ca-small" style="background:#8ecae6;">K</div>
                <div class="notif-body"><strong>Kenji</strong> started following you</div>
                <div class="notif-time">1d</div>
              </div>
            </div>
          </div>
          <div class="md:order-2">
            <div class="feature-emoji">🔔</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Never miss a kitchen update</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              Know when someone adds a recipe, comments on yours, forks your creation, or starts following you. Your kitchen community, always up to date.
            </p>
            <div class="tip-box">Notifications are smart — we won't spam you.</div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- ============================================ -->
  <!--  TAB 3: AI ASSISTANT                         -->
  <!-- ============================================ -->
  <div class="tab-panel" id="panel-ai">

    <!-- Dietary Replacements -->
    <section class="py-12 md:py-20 bg-white">
      <div class="container-wide">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div>
            <div class="feature-emoji">🥗</div>
            <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Smart dietary swaps</h2>
            <p class="text-neutral-600 leading-relaxed mb-4">
              Need dairy-free, gluten-free, or vegan? Tell the AI and it suggests ingredient substitutions that actually work — not generic swaps, but ones that maintain the recipe's flavor and texture.
            </p>
            <div class="tip-box">Works with any recipe. Just ask.</div>
          </div>
          <div class="animate-on-scroll">
            <div class="ai-visual">
              <div class="ai-chat">
                <div class="ai-msg ai-user"><div class="ai-bubble ai-bubble-user">Make this recipe dairy-free</div></div>
                <div class="ai-msg ai-assistant">
                  <div class="ai-avatar">✨</div>
                  <div class="ai-bubble ai-bubble-assistant">
                    <div class="ai-typing">Here are my suggestions:</div>
                    <div class="ai-suggestion as-1"><span class="ai-swap-old">Butter (½ cup)</span><span class="ai-swap-arrow">→</span><span class="ai-swap-new">Coconut oil (½ cup)</span></div>
