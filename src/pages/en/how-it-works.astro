---
import Layout from '../../layouts/Layout.astro';
import PhoneMockup from '../../components/PhoneMockup.astro';
import WaitlistForm from '../../components/WaitlistForm.astro';
import { useTranslations } from '../../i18n/translations';

const t = useTranslations('en');
---

<Layout title="How It Works" description="Learn how Kitchenote makes saving and organizing recipes effortless. Four simple steps from finding a recipe to cooking it.">

  <!-- Hero -->
  <section class="py-16 md:py-24">
    <div class="container-narrow text-center">
      <h1 class="mb-6">How Kitchenote works</h1>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
        Four steps. You'll figure it out in about 30 seconds.
      </p>
    </div>
  </section>

  <!-- Step 1: Find a recipe -->
  <section class="step-section py-12 md:py-20 bg-white">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div>
          <div class="step-number">1</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Find a recipe you love</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">
            Could be anywhere — your favorite food blog, that New York Times recipe your friend won't stop talking about, a YouTube video, or a recipe grandma texted you. If it's on the web, Kitchenote can save it.
          </p>
          <div class="tip-box">
            Works with 95% of recipe sites, including ones that block copying.
          </div>
        </div>
        <div class="animate-on-scroll">
          <PhoneMockup>
            <div class="demo-browse">
              <div class="demo-safari-bar">
                <div class="safari-dots">
                  <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                </div>
                <div class="safari-url">
                  <span class="safari-lock">🔒</span>
                  <span class="safari-domain">allrecipes.com</span>
                </div>
              </div>
              <div class="demo-webpage">
                <div class="webpage-hero"></div>
                <div class="webpage-title">Chicken Tikka Masala</div>
                <div class="webpage-rating">★★★★★ 4.8 (2,340 reviews)</div>
                <div class="webpage-text line-1"></div>
                <div class="webpage-text line-2"></div>
                <div class="webpage-text line-3"></div>
                <div class="webpage-ad">AD</div>
                <div class="webpage-text line-4"></div>
                <div class="webpage-text line-5"></div>
                <div class="webpage-scroll-hint">
                  <span>↓ Scroll for recipe...</span>
                </div>
              </div>
            </div>
          </PhoneMockup>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 2: Share to Kitchenote -->
  <section class="step-section py-12 md:py-20">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div class="animate-on-scroll md:order-1">
          <PhoneMockup>
            <div class="demo-share">
              <!-- Share sheet -->
              <div class="share-backdrop"></div>
              <div class="share-sheet">
                <div class="share-handle"></div>
                <div class="share-title">Share to...</div>
                <div class="share-apps">
                  <div class="share-app">
                    <div class="share-icon icon-messages">💬</div>
                    <span>Messages</span>
                  </div>
                  <div class="share-app">
                    <div class="share-icon icon-mail">✉️</div>
                    <span>Mail</span>
                  </div>
                  <div class="share-app share-app-highlight">
                    <div class="share-icon icon-kn">
                      <svg width="18" height="18" viewBox="0 0 32 32" fill="none">
                        <rect width="32" height="32" rx="8" fill="#e86f4c"/>
                        <path d="M8 10h16M8 16h12M8 22h8" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                      </svg>
                    </div>
                    <span>Kitchenote</span>
                  </div>
                  <div class="share-app">
                    <div class="share-icon icon-notes">📝</div>
                    <span>Notes</span>
                  </div>
                </div>
                <div class="share-actions">
                  <div class="share-action">Copy Link</div>
                  <div class="share-action">Add Bookmark</div>
                </div>
              </div>
            </div>
          </PhoneMockup>
        </div>
        <div class="md:order-2">
          <div class="step-number">2</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Share it to Kitchenote</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">
            Hit the share button and pick Kitchenote from the list. Or just copy the URL and paste it in the app. Either way, about two seconds.
          </p>
          <div class="tip-box">
            The share sheet method is faster, but pasting works great too.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 3: Watch the magic -->
  <section class="step-section py-12 md:py-20 bg-white">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div>
          <div class="step-number">3</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Watch the magic happen</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">
            Kitchenote reads the page and pulls out exactly what matters — title, ingredients, instructions, cook time, and photos. All the stuff you need, none of the stuff you don't.
          </p>
          <div class="tip-box">
            You can always edit or add notes to any recipe after saving.
          </div>
        </div>
        <div class="animate-on-scroll">
          <PhoneMockup>
            <div class="demo-extract">
              <div class="demo-kn-header">
                <span class="demo-kn-title">Importing...</span>
              </div>
              <div class="extract-content">
                <div class="extract-progress">
                  <div class="extract-progress-fill"></div>
                </div>
                <div class="extract-status">Reading page...</div>
                <div class="extract-items">
                  <div class="extract-item ei-1"><span class="extract-check">✓</span> Title found</div>
                  <div class="extract-item ei-2"><span class="extract-check">✓</span> 12 ingredients</div>
                  <div class="extract-item ei-3"><span class="extract-check">✓</span> 6 steps</div>
                  <div class="extract-item ei-4"><span class="extract-check">✓</span> Cook time: 45 min</div>
                  <div class="extract-item ei-5"><span class="extract-check">✓</span> Photo saved</div>
                </div>
                <div class="extract-done">
                  <div class="extract-done-icon">✨</div>
                  <div class="extract-done-text">Recipe saved!</div>
                </div>
              </div>
            </div>
          </PhoneMockup>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 3.5: Website vs App comparison -->
  <section class="step-section py-12 md:py-20">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">See the difference</h2>
        <p class="text-neutral-600 max-w-2xl mx-auto">
          Same recipe. Completely different experience.
        </p>
      </div>
      <div class="comparison animate-on-scroll">
        <div class="comparison-grid">
          <!-- Website side -->
          <div class="compare-side compare-website">
            <div class="compare-label compare-label-bad">Recipe website</div>
            <PhoneMockup>
              <div class="web-mess">
                <div class="web-mess-bar">
                  <div class="web-mess-dots"><span></span><span></span><span></span></div>
                  <div class="web-mess-url">foodblog.com/best-ever-tikka</div>
                </div>
                <div class="web-mess-content">
                  <div class="web-mess-popup">
                    <div class="popup-x">✕</div>
                    <div class="popup-text">Subscribe for FREE recipes!</div>
                    <div class="popup-input"></div>
                  </div>
                  <div class="web-mess-hero-img"></div>
                  <div class="web-mess-title">The BEST Chicken Tikka Masala You'll Ever Make (I Promise!)</div>
                  <div class="web-mess-meta">By Jessica • March 12, 2025 • 847 comments</div>
                  <div class="web-mess-story">
                    <div class="wm-line" style="width:100%"></div>
                    <div class="wm-line" style="width:92%"></div>
                    <div class="wm-line" style="width:88%"></div>
                  </div>
                  <div class="web-mess-ad">ADVERTISEMENT</div>
                  <div class="web-mess-story">
                    <div class="wm-line" style="width:95%"></div>
                    <div class="wm-line" style="width:85%"></div>
                    <div class="wm-line" style="width:90%"></div>
                    <div class="wm-line" style="width:78%"></div>
                  </div>
                  <div class="web-mess-inline-img"></div>
                  <div class="web-mess-story">
                    <div class="wm-line" style="width:100%"></div>
                    <div class="wm-line" style="width:88%"></div>
                  </div>
                  <div class="web-mess-ad">SPONSORED</div>
                  <div class="web-mess-story">
                    <div class="wm-line" style="width:92%"></div>
                    <div class="wm-line" style="width:96%"></div>
                    <div class="wm-line" style="width:80%"></div>
                  </div>
                  <!-- more filler text to show the scroll continues -->
                  <div class="web-mess-story"><div class="wm-line" style="width:94%"></div><div class="wm-line" style="width:82%"></div></div>
                </div>
              </div>
            </PhoneMockup>
            <div class="compare-issues">
              <div class="issue">❌ 2,000-word life story</div>
              <div class="issue">❌ Pop-ups and ads</div>
              <div class="issue">❌ Needs internet</div>
              <div class="issue">❌ Can't scale servings</div>
            </div>
          </div>

          <!-- Kitchenote side -->
          <div class="compare-side compare-app">
            <div class="compare-label compare-label-good">In Kitchenote</div>
            <PhoneMockup>
              <div class="app-clean">
                <div class="app-clean-header">
                  <span class="app-clean-back">‹</span>
                  <span class="app-clean-title">Chicken Tikka Masala</span>
                  <span class="app-clean-edit">✎</span>
                </div>
                <div class="app-clean-img"></div>
                <div class="app-clean-body">
                  <div class="app-clean-name">Chicken Tikka Masala</div>
                  <div class="app-clean-meta-row">
                    <span class="app-meta-pill">🕐 45 min</span>
                    <span class="app-meta-pill">👤 4 servings</span>
                    <span class="app-meta-pill">⭐ Saved</span>
                  </div>
                  <div class="app-clean-section-title">Ingredients</div>
                  <div class="app-clean-ing"><span class="ing-qty">500g</span> chicken thigh</div>
                  <div class="app-clean-ing"><span class="ing-qty">1 cup</span> yogurt</div>
                  <div class="app-clean-ing"><span class="ing-qty">2 tbsp</span> garam masala</div>
                  <div class="app-clean-ing"><span class="ing-qty">400g</span> crushed tomatoes</div>
                  <div class="app-clean-ing"><span class="ing-qty">1 tbsp</span> olive oil</div>
                  <div class="app-clean-section-title">Steps</div>
                  <div class="app-clean-step"><span class="step-num">1</span> Marinate chicken in yogurt and spices for 30 min</div>
                  <div class="app-clean-step"><span class="step-num">2</span> Heat oil, cook chicken until golden</div>
                </div>
                <div class="app-clean-cook-btn">🍳 Start Cook Mode</div>
              </div>
            </PhoneMockup>
            <div class="compare-wins">
              <div class="win">✅ Just the recipe</div>
              <div class="win">✅ No ads, no pop-ups</div>
              <div class="win">✅ Works offline</div>
              <div class="win">✅ Scale to any serving size</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 4: Cook -->
  <section class="step-section py-12 md:py-20">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div class="animate-on-scroll md:order-1">
          <PhoneMockup>
            <div class="demo-final">
              <div class="demo-kn-header">
                <span class="demo-kn-title">My Recipes</span>
              </div>
              <div class="final-grid">
                <div class="final-card fc-1">
                  <div class="final-thumb" style="background: url('/images/recipes/tikka-masala.jpg') center/cover;"></div>
                  <div class="final-info">
                    <div class="final-name">Tikka Masala</div>
                    <div class="final-time">45 min</div>
                  </div>
                </div>
                <div class="final-card fc-2">
                  <div class="final-thumb" style="background: url('/images/recipes/caesar-salad.jpg') center/cover;"></div>
                  <div class="final-info">
                    <div class="final-name">Caesar Salad</div>
                    <div class="final-time">15 min</div>
                  </div>
                </div>
                <div class="final-card fc-3">
                  <div class="final-thumb" style="background: url('/images/recipes/banana-bread.jpg') center/cover;"></div>
                  <div class="final-info">
                    <div class="final-name">Banana Bread</div>
                    <div class="final-time">60 min</div>
                  </div>
                </div>
                <div class="final-card fc-4">
                  <div class="final-thumb" style="background: url('/images/recipes/pad-thai.jpg') center/cover;"></div>
                  <div class="final-info">
                    <div class="final-name">Pad Thai</div>
                    <div class="final-time">30 min</div>
                  </div>
                </div>
                <div class="final-card fc-5">
                  <div class="final-thumb" style="background: url('/images/recipes/berry-smoothie.jpg') center/cover;"></div>
                  <div class="final-info">
                    <div class="final-name">Berry Smoothie</div>
                    <div class="final-time">5 min</div>
                  </div>
                </div>
                <div class="final-card fc-6">
                  <div class="final-thumb" style="background: url('/images/recipes/miso-soup.jpg') center/cover;"></div>
                  <div class="final-info">
                    <div class="final-name">Miso Soup</div>
                    <div class="final-time">20 min</div>
                  </div>
                </div>
              </div>
              <!-- Cook mode button -->
              <div class="final-cook-btn">
                <span>🍳</span> Start Cooking
              </div>
            </div>
          </PhoneMockup>
        </div>
        <div class="md:order-2">
          <div class="step-number">4</div>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Cook whenever you're ready</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">
            Your recipes are saved, organized, and waiting. Open Cook Mode when it's time to actually make something — big text, step-by-step, no distractions. Just you and the food.
          </p>
          <div class="tip-box">
            All recipes work offline. No WiFi in the kitchen? No problem.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16">
    <div class="container-narrow">
      <h2 class="text-2xl font-display font-bold text-center mb-8">Quick questions</h2>
      <div class="space-y-4">
        <details class="group card">
          <summary class="flex items-center justify-between cursor-pointer list-none font-medium">
            What if a recipe doesn't import correctly?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-neutral-600">Happens occasionally with unusual page layouts. You can always edit any recipe manually. We're constantly improving our parser too.</p>
        </details>
        <details class="group card">
          <summary class="flex items-center justify-between cursor-pointer list-none font-medium">
            Can I add my own recipes?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-neutral-600">Absolutely. Create a recipe from scratch anytime. Great for family recipes or your own creations.</p>
        </details>
        <details class="group card">
          <summary class="flex items-center justify-between cursor-pointer list-none font-medium">
            Does it work with sites that require login?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-neutral-600">Most of the time, yes! If you can see the recipe, we can usually save it. Some heavily protected sites might not work, but we're always adding support.</p>
        </details>
      </div>
      <p class="text-center mt-8">
        <a href="/en/support" class="text-primary-600 hover:text-primary-700 font-medium">More questions? Check our full FAQ →</a>
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-br from-primary-500 to-primary-600 text-white">
    <div class="container-narrow text-center">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-4 text-white">Simple enough, right?</h2>
      <p class="text-primary-100 mb-8">Sign up and we'll let you know when Kitchenote launches.</p>
      <WaitlistForm />
    </div>
  </section>

</Layout>

<style>
  .step-number {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #e86f4c;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Poppins', system-ui, sans-serif;
    font-weight: 700;
    font-size: 20px;
    margin-bottom: 16px;
    box-shadow: 0 4px 16px rgba(232, 111, 76, 0.25);
  }

  .tip-box {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: #f6f7f4;
    border-radius: 10px;
    font-size: 14px;
    color: #5d714a;
    border-left: 3px solid #788d61;
  }

  .animate-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .animate-on-scroll.in-view { opacity: 1; transform: translateY(0); }

  /* ===== Step 1: Browse animation ===== */
  .demo-browse { width: 100%; height: 100%; display: flex; flex-direction: column; }

  .demo-safari-bar {
    padding: 48px 12px 8px;
    background: #f2f2f7;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .safari-dots { display: flex; gap: 5px; padding: 0 4px; }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: #d1d1d6; }

  .safari-url {
    background: white;
    border-radius: 8px;
    padding: 6px 10px;
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
  }
  .safari-lock { font-size: 10px; }
  .safari-domain { color: #27272a; font-weight: 500; }

  .demo-webpage { flex: 1; padding: 8px 12px; overflow: hidden; }

  .webpage-hero {
    height: 72px;
    border-radius: 8px;
    background: linear-gradient(135deg, #f4a261, #e76f51);
    margin-bottom: 10px;
  }
  .webpage-title { font-size: 14px; font-weight: 700; color: #27272a; margin-bottom: 3px; }
  .webpage-rating { font-size: 10px; color: #f59e0b; margin-bottom: 8px; }
  .webpage-text { height: 8px; background: #e8e4de; border-radius: 4px; margin-bottom: 6px; }
  .line-1 { width: 100%; }
  .line-2 { width: 85%; }
  .line-3 { width: 92%; }
  .line-4 { width: 78%; }
  .line-5 { width: 88%; }
  .webpage-ad {
    background: #fef0eb;
    color: #e86f4c;
    font-size: 8px;
    font-weight: 700;
    padding: 8px;
    border-radius: 6px;
    text-align: center;
    margin: 8px 0;
    border: 1px dashed #f4a261;
  }
  .webpage-scroll-hint {
    text-align: center;
    font-size: 10px;
    color: #a1a1aa;
    margin-top: 8px;
    animation: scrollHintPulse 2s ease-in-out infinite;
  }
  @keyframes scrollHintPulse {
    0%, 100% { opacity: 0.4; transform: translateY(0); }
    50% { opacity: 1; transform: translateY(3px); }
  }

  /* ===== Step 2: Share sheet ===== */
  .demo-share {
    width: 100%;
    height: 100%;
    position: relative;
    background: #f2f2f7;
  }

  .share-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
  }

  .share-sheet {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: white;
    border-radius: 16px 16px 0 0;
    padding: 12px 16px 24px;
    animation: sheetSlideUp 3s cubic-bezier(0.16, 1, 0.3, 1) infinite;
  }

  @keyframes sheetSlideUp {
    0%, 10% { transform: translateY(100%); }
    25%, 85% { transform: translateY(0); }
    95%, 100% { transform: translateY(100%); }
  }

  .share-handle {
    width: 36px;
    height: 4px;
    background: #d1d1d6;
    border-radius: 2px;
    margin: 0 auto 12px;
  }

  .share-title {
    font-size: 13px;
    font-weight: 600;
    color: #27272a;
    margin-bottom: 14px;
  }

  .share-apps {
    display: flex;
    gap: 16px;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid #f0f0f0;
  }

  .share-app {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    font-size: 9px;
    color: #71717a;
  }

  .share-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    background: #f0f0f0;
  }

  .share-app-highlight .share-icon {
    background: transparent;
    box-shadow: 0 0 0 2px #e86f4c;
    animation: highlightPulse 3s ease-in-out infinite;
  }

  @keyframes highlightPulse {
    0%, 30% { box-shadow: 0 0 0 2px transparent; }
    45%, 75% { box-shadow: 0 0 0 2px #e86f4c, 0 0 12px rgba(232, 111, 76, 0.3); }
    90%, 100% { box-shadow: 0 0 0 2px transparent; }
  }

  .share-app-highlight span { color: #e86f4c; font-weight: 600; }

  .share-actions { display: flex; flex-direction: column; gap: 1px; }
  .share-action {
    padding: 10px;
    font-size: 13px;
    color: #007aff;
    background: #f8f8fa;
    text-align: center;
  }
  .share-action:first-child { border-radius: 10px 10px 0 0; }
  .share-action:last-child { border-radius: 0 0 10px 10px; }

  /* ===== Step 3: Extract animation (non-absolute, simple) ===== */
  .demo-extract {
    width: 100%;
    height: 100%;
  }

  .demo-kn-header {
    padding: 52px 18px 10px;
    text-align: center;
  }

  .demo-kn-title {
    font-size: 16px;
    font-weight: 700;
    color: #27272a;
  }

  .extract-content {
    padding: 12px 18px;
  }

  .extract-progress {
    height: 4px;
    background: #f0ebe6;
    border-radius: 2px;
    overflow: hidden;
