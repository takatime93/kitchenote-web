---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={['phone-wrapper', className]}>
  <div class="phone-glow"></div>
  <div class="phone-frame">
    <div class="phone-island"></div>
    <div class="phone-screen">
      <slot />
    </div>
  </div>
</div>

<style>
  .phone-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .phone-glow {
    position: absolute;
    width: 140%;
    height: 140%;
    background: radial-gradient(circle, rgba(232, 111, 76, 0.08) 0%, transparent 65%);
    filter: blur(40px);
    pointer-events: none;
  }

  .phone-frame {
    position: relative;
    width: 260px;
    height: 532px;
    background: linear-gradient(145deg, #1d1d1f, #2d2d2f);
    border-radius: 44px;
    padding: 11px;
    box-shadow:
      0 0 0 1.5px #3a3a3c,
      0 30px 80px -15px rgba(0, 0, 0, 0.35),
      0 10px 30px -5px rgba(0, 0, 0, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .phone-island {
    width: 92px;
    height: 25px;
    background: #000;
    border-radius: 14px;
    position: absolute;
    top: 19px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    background: #fefdfb;
    border-radius: 36px;
    overflow: hidden;
    position: relative;
  }

  @media (max-width: 768px) {
    .phone-frame {
      width: 220px;
      height: 450px;
      border-radius: 38px;
      padding: 10px;
    }
    .phone-screen {
      border-radius: 30px;
    }
    .phone-island {
      width: 78px;
      height: 22px;
      top: 16px;
    }
  }
</style>
