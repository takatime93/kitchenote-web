---
interface Props {
  number: number;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<div class="relative">
  <!-- Step number -->
  <div class="absolute -left-4 md:left-0 w-8 h-8 rounded-full bg-primary-500 text-white flex items-center justify-center font-display font-bold text-sm">
    {number}
  </div>

  <div class="pl-8 md:pl-12">
    <h3 class="text-lg font-display font-bold text-neutral-900 mb-2">
      {title}
    </h3>
    <p class="text-neutral-600 leading-relaxed">
      {description}
    </p>
  </div>
</div>
