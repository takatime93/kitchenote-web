---
import { getLangFromUrl, useTranslations } from '../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="waitlist-form">
  <form id="waitlist" class="waitlist-inner" action="#" method="POST">
    <div class="input-group">
      <input
        type="email"
        name="email"
        required
        placeholder={lang === 'ja' ? 'メールアドレス' : 'you@email.com'}
        class="waitlist-input"
      />
      <button type="submit" class="waitlist-btn">
        {lang === 'ja' ? '通知を受け取る' : 'Notify me'}
      </button>
    </div>
    <p class="waitlist-note">
      {lang === 'ja' ? 'スパムは送りません。リリース時にお知らせするだけです。' : "No spam. We'll only email you when we launch."}
    </p>
    <p class="waitlist-success" id="waitlist-success">
      {lang === 'ja' ? '登録完了！リリース時にお知らせします。' : "You're on the list! We'll let you know when we launch."}
    </p>
  </form>
</div>

<style>
  .waitlist-form {
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
  }

  .input-group {
    display: flex;
    gap: 8px;
    background: white;
    border: 2px solid #e8e4de;
    border-radius: 14px;
    padding: 5px;
    transition: border-color 0.2s;
  }

  .input-group:focus-within {
    border-color: #e86f4c;
  }

  .waitlist-input {
    flex: 1;
    padding: 12px 16px;
    border: none;
    background: transparent;
    font-size: 15px;
    color: #27272a;
    outline: none;
    font-family: inherit;
    min-width: 0;
  }

  .waitlist-input::placeholder {
    color: #a1a1aa;
  }

  .waitlist-btn {
    padding: 12px 24px;
    background: #e86f4c;
    color: white;
    border: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    white-space: nowrap;
    font-family: inherit;
  }

  .waitlist-btn:hover {
    background: #d4603f;
  }

  .waitlist-btn:active {
    transform: scale(0.97);
  }

  .waitlist-note {
    text-align: center;
    font-size: 13px;
    color: #71717a;
    margin-top: 10px;
  }

  .waitlist-success {
    text-align: center;
    font-size: 14px;
    color: #788d61;
    font-weight: 600;
    margin-top: 10px;
    display: none;
  }

  @media (max-width: 480px) {
    .input-group {
      flex-direction: column;
    }
    .waitlist-btn {
      width: 100%;
    }
  }
</style>

<script>
  const form = document.getElementById('waitlist') as HTMLFormElement;
  const success = document.getElementById('waitlist-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const email = data.get('email');

    // TODO: Replace with Formspree, Mailchimp, or your email service endpoint
    // Example: fetch('https://formspree.io/f/YOUR_ID', { method: 'POST', body: data })
    console.log('Waitlist signup:', email);

    // Show success state
    form.querySelector('.input-group')?.classList.add('hidden');
    form.querySelector('.waitlist-note')?.classList.add('hidden');
    if (success) success.style.display = 'block';
  });
</script>
