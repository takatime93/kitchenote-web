---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const productLinks = [
  { key: 'nav.features', path: '/features' },
  { key: 'nav.howItWorks', path: '/how-it-works' },
  { key: 'nav.support', path: '/support' },
] as const;

const companyLinks = [
  { key: 'nav.about', path: '/about' },
  { key: 'nav.blog', path: '/blog' },
] as const;

const legalLinks = [
  { key: 'footer.privacy', path: '/privacy' },
  { key: 'footer.terms', path: '/terms' },
] as const;
---

<footer class="bg-neutral-900 text-neutral-300 py-16">
  <div class="container-wide">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand Column -->
      <div class="col-span-2 md:col-span-1">
        <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2 text-white mb-4">
          <svg class="w-8 h-8 text-primary-400" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="currentColor"/>
            <path d="M8 10h16M8 16h12M8 22h8" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <span class="font-display font-bold text-xl">Kitchenote</span>
        </a>
        <p class="text-sm text-neutral-400 mb-6">
          {t('footer.tagline')}
        </p>
        <!-- App Store Badge — uncomment when app is live
        <a href="#" class="inline-block">
          <img src="/images/app-store-badge.svg" alt="Download on the App Store" class="h-10" width="120" height="40" />
        </a> -->
      </div>

      <!-- Product Links -->
      <div>
        <h4 class="text-white font-display font-semibold mb-4">{t('footer.product')}</h4>
        <ul class="space-y-3">
          {productLinks.map(({ key, path }) => (
            <li>
              <a
                href={getLocalizedPath(path, lang)}
                class="text-sm text-neutral-400 hover:text-white transition-colors"
              >
                {t(key)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company Links -->
      <div>
        <h4 class="text-white font-display font-semibold mb-4">{t('footer.company')}</h4>
        <ul class="space-y-3">
          {companyLinks.map(({ key, path }) => (
            <li>
              <a
                href={getLocalizedPath(path, lang)}
                class="text-sm text-neutral-400 hover:text-white transition-colors"
              >
                {t(key)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal Links -->
      <div>
        <h4 class="text-white font-display font-semibold mb-4">{t('footer.legal')}</h4>
        <ul class="space-y-3">
          {legalLinks.map(({ key, path }) => (
            <li>
              <a
                href={getLocalizedPath(path, lang)}
                class="text-sm text-neutral-400 hover:text-white transition-colors"
              >
                {t(key)}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-neutral-800 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-neutral-500">
        {t('footer.copyright')}
      </p>
      <!-- Social Links — add real URLs when available -->
    </div>
  </div>
</footer>
